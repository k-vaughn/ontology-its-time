// Diagram for Period
digraph {
	graph [overlap=false rankdir=TB splines=true]
	node [fontname=Arial fontsize=12 margin=0 shape=none]
	edge [fontname=Arial fontsize=11]
	{
		rank=source
		ScheduleThing [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">ScheduleThing</TD></TR></TABLE>> URL="../ScheduleThing" margin=0]
	}
	Period [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">Period</TD></TR><TR><TD ALIGN="LEFT">cdm1:hasName : rdf:langString</TD></TR><TR><TD ALIGN="LEFT">endOfPeriod : xsd:dateTime [0..1]</TD></TR><TR><TD ALIGN="LEFT">startOfPeriod : xsd:dateTime [0..1]</TD></TR></TABLE>> URL="../Period" margin=0]
	{
		rank=max
	}
	subgraph cluster_associated {
		label="" style=invis
		Invis [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD></TD></TR></TABLE>> margin=0 style=invis]
		DayWeekMonth [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">DayWeekMonth</TD></TR></TABLE>> URL="../DayWeekMonth" margin=0]
		SpecialDay [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">SpecialDay</TD></TR></TABLE>> URL="../SpecialDay" margin=0]
		TimePeriodOfDay [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">TimePeriodOfDay</TD></TR></TABLE>> URL="../TimePeriodOfDay" margin=0]
	}
	Period -> ScheduleThing [arrowhead=onormal style=solid]
	Period -> Invis [style=invis]
	Invis -> DayWeekMonth [style=invis]
	DayWeekMonth -> SpecialDay [style=invis]
	SpecialDay -> TimePeriodOfDay [style=invis]
	DayWeekMonth [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">DayWeekMonth</TD></TR></TABLE>> URL="../DayWeekMonth" margin=0]
	Period -> DayWeekMonth [label="hasRecurringDayWeekMonthPeriod
0..1" arrowhead=normal style=solid]
	SpecialDay [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">SpecialDay</TD></TR></TABLE>> URL="../SpecialDay" margin=0]
	Period -> SpecialDay [label="hasRecurringSpecialDay
0..1" arrowhead=normal style=solid]
	TimePeriodOfDay [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">TimePeriodOfDay</TD></TR></TABLE>> URL="../TimePeriodOfDay" margin=0]
	Period -> TimePeriodOfDay [label="hasRecurringTimePeriodOfDay
0..1" arrowhead=normal style=solid]
}
