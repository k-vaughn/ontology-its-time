// Diagram for SpecialDay
digraph {
	graph [overlap=false rankdir=TB splines=true]
	node [fontname=Arial fontsize=12 margin=0 shape=none]
	edge [fontname=Arial fontsize=11]
	{
		rank=source
		ScheduleThing [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">ScheduleThing</TD></TR></TABLE>> URL="../ScheduleThing" margin=0]
	}
	SpecialDay [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">SpecialDay</TD></TR><TR><TD ALIGN="LEFT">intersectWithApplicableDays : xsd:boolean [1]</TD></TR></TABLE>> URL="../SpecialDay" margin=0]
	{
		rank=max
	}
	subgraph cluster_associated {
		label="" style=invis
		Invis [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD></TD></TR></TABLE>> margin=0 style=invis]
		cdm2_NamedArea [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">cdm2:NamedArea</TD></TR></TABLE>> URL="https://w3id.org/citydata/part2/v1/NamedArea" margin=0]
		PublicEventCode [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">PublicEventCode</TD></TR></TABLE>> URL="../PublicEventCode" margin=0]
		SpecialDayTypeCode [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">SpecialDayTypeCode</TD></TR></TABLE>> URL="../SpecialDayTypeCode" margin=0]
	}
	SpecialDay -> ScheduleThing [arrowhead=onormal style=solid]
	SpecialDay -> Invis [style=invis]
	Invis -> cdm2_NamedArea [style=invis]
	cdm2_NamedArea -> PublicEventCode [style=invis]
	PublicEventCode -> SpecialDayTypeCode [style=invis]
	SpecialDayTypeCode [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">SpecialDayTypeCode</TD></TR></TABLE>> URL="../SpecialDayTypeCode" margin=0]
	SpecialDay -> SpecialDayTypeCode [label="hasSpecialDayType
1" arrowhead=normal style=solid]
	PublicEventCode [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">PublicEventCode</TD></TR></TABLE>> URL="../PublicEventCode" margin=0]
	SpecialDay -> PublicEventCode [label="hasPublicEventType
0..1" arrowhead=normal style=solid]
	cdm2_NamedArea [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">cdm2:NamedArea</TD></TR></TABLE>> URL="https://w3id.org/citydata/part2/v1/NamedArea" margin=0]
	SpecialDay -> cdm2_NamedArea [label="applicableArea
0..1" arrowhead=normal style=solid]
}
