// Diagram for Schedule
digraph {
	graph [overlap=false rankdir=TB splines=true]
	node [fontname=Arial fontsize=12 margin=0 shape=none]
	edge [fontname=Arial fontsize=11]
	{
		rank=source
		ScheduleThing [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">ScheduleThing</TD></TR></TABLE>> URL="../ScheduleThing" margin=0]
	}
	Schedule [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">Schedule</TD></TR><TR><TD ALIGN="LEFT">isOverrunning : xsd:boolean [0..1]</TD></TR></TABLE>> URL="../Schedule" margin=0]
	{
		rank=max
	}
	subgraph cluster_associated {
		label="" style=invis
		Invis [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD></TD></TR></TABLE>> margin=0 style=invis]
		OverallPeriod [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">OverallPeriod</TD></TR></TABLE>> URL="../OverallPeriod" margin=0]
		ValidityStatusCode [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">ValidityStatusCode</TD></TR></TABLE>> URL="../ValidityStatusCode" margin=0]
	}
	Schedule -> ScheduleThing [arrowhead=onormal style=solid]
	Schedule -> Invis [style=invis]
	Invis -> OverallPeriod [style=invis]
	OverallPeriod -> ValidityStatusCode [style=invis]
	OverallPeriod [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">OverallPeriod</TD></TR></TABLE>> URL="../OverallPeriod" margin=0]
	Schedule -> OverallPeriod [label="validityTimeSpecification
1" arrowhead=normal style=solid]
	ValidityStatusCode [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">ValidityStatusCode</TD></TR></TABLE>> URL="../ValidityStatusCode" margin=0]
	Schedule -> ValidityStatusCode [label="hasValidityStatus
1" arrowhead=normal style=solid]
}
