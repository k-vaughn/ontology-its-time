// Diagram for OverallPeriod
digraph {
	graph [overlap=false rankdir=TB splines=true]
	node [fontname=Arial fontsize=12 margin=0 shape=none]
	edge [fontname=Arial fontsize=11]
	{
		rank=source
		ScheduleThing [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">ScheduleThing</TD></TR></TABLE>> URL="../ScheduleThing" margin=0]
	}
	OverallPeriod [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">OverallPeriod</TD></TR><TR><TD ALIGN="LEFT">overallEndTime : xsd:dateTime [0..1]</TD></TR><TR><TD ALIGN="LEFT">overallStartTime : xsd:dateTime [1]</TD></TR></TABLE>> URL="../OverallPeriod" margin=0]
	{
		rank=max
	}
	subgraph cluster_associated {
		label="" style=invis
		Invis [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD></TD></TR></TABLE>> margin=0 style=invis]
		Period [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">Period</TD></TR></TABLE>> URL="../Period" margin=0]
	}
	OverallPeriod -> ScheduleThing [arrowhead=onormal style=solid]
	OverallPeriod -> Invis [style=invis]
	Invis -> Period [style=invis]
	Period [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">Period</TD></TR></TABLE>> URL="../Period" margin=0]
	OverallPeriod -> Period [label=validPeriod arrowhead=normal style=solid]
	OverallPeriod -> Period [label=exceptionPeriod arrowhead=normal style=solid]
}
