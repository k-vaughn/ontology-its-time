# =====================================================
# ReqView Annotations
# =====================================================

@prefix : <https://w3id.org/itsdata/time/v1/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix its-core: <https://w3id.org/itsdata/core/v1/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
		
:ReqView a owl:Ontology;
    # Ontology metadata
    dcterms:title                  "Time Ontology for ITS - ReqView annotations."@en;
    skos:definition                "This ontology defines the identifiers used by ReqView to manage traceability and use of ontology concepts within ITS."@en;
    dcterms:license                "http://creativecommons.org/licenses/by/4.0/";
    dcterms:modified               "2026-04-15T13:59:32"^^xsd:dateTime .


# FuzzyTime
:FuzzyTime a owl:Class ;
    its-core:reqviewId "its-time-1" .

# DayWeekMonth
:DayWeekMonth a owl:Class ;
    its-core:reqviewId "its-time-2" .

# ValidityStatusCode
:ValidityStatusCode a owl:Class ;
    its-core:reqviewId "its-time-3" .

