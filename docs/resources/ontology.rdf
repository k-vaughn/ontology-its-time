                    <rdf:Description rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#damagedViaduct"/>
                    <rdf:Description rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#fallenPowerCables"/>
                    <rdf:Description rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#gasLeak"/>
