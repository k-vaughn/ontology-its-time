                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#ConstructionWorkTypeEnum"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <skos:definition xml:lang="en">Roadworks involving the construction of new infrastructure.</skos:definition>
    </owl:Class>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#DataValue -->


    <owl:Class rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#DataValue">
        <rdfs:subClassOf rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#CommonClasses"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasComputationMethodEnum"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onClass rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#ComputationMethodEnum"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#accuracy"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://qudt.org/schema/qudt/floatPercentage"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#dataError"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#numberOfIncompleteInputs"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#numberOfInputValuesUsed"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#reasonForDataError"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#smoothingFactor"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#standardDeviation"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#supplierCalculatedDataQuality"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://qudt.org/schema/qudt/floatPercentage"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <skos:definition xml:lang="en">A data value of something that can be measured or calculated. Any provided meta-data values specified in the attributes override any specified generic characteristics such as defined for a specific measurement in the MeasurementSiteTable.</skos:definition>
    </owl:Class>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#DelayBandEnum -->


    <owl:Class rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#DelayBandEnum">
        <owl:equivalentClass>
            <owl:Class>
                <owl:oneOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#betweenOneHourAndThreeHours"/>
                    <rdf:Description rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#betweenTenMinutesAndThirtyMinutes"/>
                    <rdf:Description rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#betweenThirtyMinutesAndOneHour"/>
                    <rdf:Description rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#betweenThreeHoursAndSixHours"/>
                    <rdf:Description rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#longerThanSixHours"/>
                    <rdf:Description rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#negligible"/>
                    <rdf:Description rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#upToTenMinutes"/>
                </owl:oneOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#Non-SRTI_Enum"/>
        <skos:definition xml:lang="en">The time band within which the additional travel time due to adverse travel conditions of any kind falls, when compared to &quot;normal conditions&quot;.</skos:definition>
    </owl:Class>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#Delays -->


    <owl:Class rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#Delays">
        <rdfs:subClassOf rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#CommonClasses"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#delayBand"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onClass rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#DelayBandEnum"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#delaysType"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onClass rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#DelaysTypeEnum"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#delayTimeValue"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <skos:definition xml:lang="en">The details of the delays being caused by the situation element defined in the situation record. It is recommended to only use one of the optional attributes to avoid confusion.</skos:definition>
    </owl:Class>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#DelaysTypeEnum -->


    <owl:Class rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#DelaysTypeEnum">
        <owl:equivalentClass>
            <owl:Class>
                <owl:oneOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#delays"/>
                    <rdf:Description rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#delaysOfUncertainDuration"/>
                    <rdf:Description rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#longDelays"/>
                    <rdf:Description rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#veryLongDelays"/>
                </owl:oneOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#Non-SRTI_Enum"/>
        <skos:definition xml:lang="en">Coarse classification of the delay.</skos:definition>
    </owl:Class>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#DirectionEnum -->

    <owl:Class rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#DirectionEnum">
