            <owl:Restriction>
                <owl:onProperty rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#temporarySpeedLimit"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onClass rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#SpeedValue"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <skos:definition xml:lang="en">Speed management action that is instigated by the network/road operator.</skos:definition>
    </owl:Class>
    


