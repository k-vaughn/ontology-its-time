                <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minQualifiedCardinality>
                <owl:onClass rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#ReroutingManagementTypeEnum"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <skos:definition xml:lang="en">Rerouting management action that is issued by the network/road operator.</skos:definition>
    </owl:Class>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#ReroutingManagementTypeEnum -->


    <owl:Class rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#ReroutingManagementTypeEnum">
