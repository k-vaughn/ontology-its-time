    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#Impact -->


    <owl:Class rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#Impact">
        <rdfs:subClassOf rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#CommonClasses"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasDelays"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onClass rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#Delays"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#residualLaneWidth"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onClass rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#MetresAsFloatValue"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#residualRoadWidth"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onClass rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#MetresAsFloatValue"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#capacityRemaining"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://qudt.org/schema/qudt/floatPercentage"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#numberOfLanesRestricted"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#numberOfOperationalLanes"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <skos:definition xml:lang="en">An assessment of the impact that an event or operator action defined by the situation record has on the driving conditions.</skos:definition>
    </owl:Class>
    


