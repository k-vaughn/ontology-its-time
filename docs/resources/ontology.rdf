    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#HeightTypeEnum -->


    <owl:Class rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#HeightTypeEnum">
