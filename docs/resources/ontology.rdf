DATEX II SRTI profile RDF/OWL vocabulary
    <dcterms:source>http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti</dcterms:source>
    <dcterms:contributor>Tam Tam Research, CVUT, ESAM Technologies &amp; LMT.</dcterms:contributor>
    <dcterms:contributor>Julian Gutierrez Moret (https://www.uv.es/uvweb/universidad/es/ficha-persona-1285950309813.html?p2=gumoju)

BOLA Time
    https://www.semantic-web-journal.net/system/files/swj3682.pdf


<?xml version="1.0"?>
<rdf:RDF xmlns="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#"
     xml:base="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti"
     xmlns:dc="http://purl.org/dc/elements/1.1/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:adms="http://www.w3.org/ns/adms#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:skos="http://www.w3.org/2004/02/skos/core#"
     xmlns:time="http://www.w3.org/2006/time#"
     xmlns:vann="http://purl.org/vocab/vann/"
     xmlns:terms="http://purl.org/dc/terms/"
     xmlns:schema="https://schema.org/"
     xmlns:dtx_srti="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#"
     xmlns:geographic="http://ec.europa.eu/eurostat/ramon/ontologies/geographic.rdf#"
     xmlns:geographic1="https://ec.europa.eu/eurostat/ramon/ontologies/geographic.rdf#">
    <owl:Ontology rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti">
        <owl:imports rdf:resource="http://www.opengis.net/ont/geosparql"/>
        <owl:imports rdf:resource="http://www.w3.org/2006/time#2016"/>
        <owl:imports rdf:resource="https://ec.europa.eu/eurostat/ramon/ontologies/geographic.rdf"/>
        <dc:date xml:lang="en">2022-03-31</dc:date>
        <dc:source xml:lang="en">https://docs.datex2.eu/_static/data/v3.2/umlmodel/html/index.htm</dc:source>
        <terms:contributor xml:lang="en">Tam Tam Research, CVUT, ESAM Technologies &amp; LMT.</terms:contributor>
        <terms:creator xml:lang="en">Julian Gutierrez Moret (https://www.uv.es/uvweb/universidad/es/ficha-persona-1285950309813.html?p2=gumoju) 

J. Javier Samper Zapater (https://www.uv.es/uvweb/college/en/profile-1285950309813.html?p2=jjsamper&amp;idA=true) 

IRTIC - (Instituto de Robótica y Tecnologías de la Información y la Comunicación)</terms:creator>
        <terms:description xml:lang="en">An RDF/OWL vocabulary to represent SRTI DATEX II profile (according the Commission  Delegated Regulation (EU) No 886/2013) within the European  LOD-RoadTran18 action  &quot;Supporting the cross-border use of Road Traffic Data with Linked Open Data based on DATEX II (LOD-RoadTran18)&quot; (Agreement No: INEA/CEF/ICT/A2018/1803421, Action No: 2018-EU-IA-0088). The  vocabulary is used for mapping between DATEX II and LOD formats.</terms:description>
        <terms:license>https://creativecommons.org/licenses/by/4.0/</terms:license>
        <terms:publisher xml:lang="es">IRTIC - (Instituto de Robótica y Tecnologías de la Información y la Comunicación)</terms:publisher>
        <terms:title xml:lang="en">LOD SRTI DATEX II</terms:title>
        <vann:preferredNamespacePrefix xml:lang="en">dtx_srti</vann:preferredNamespacePrefix>
        <vann:preferredNamespaceUri xml:lang="en">http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#</vann:preferredNamespaceUri>
        <rdfs:seeAlso xml:lang="en">http://cef.uv.es/lodroadtran18/</rdfs:seeAlso>
        <owl:versionInfo xml:lang="en">1.0</owl:versionInfo>
        <skos:changeNote xml:lang="en">2022-02-01. Extended the ontology with non-SRTI elements and adition of the comments:

	- Related with a SituationRecord: Severity, Source &amp; Impact 
	- New items for old SRTI Enumerations and new non-SRTI Enumerations 
	- Added Mobility</skos:changeNote>
        <skos:changeNote xml:lang="en">2022-07-29. Use of  LCC Country Representation  alpha2code and LCC Language Representation  alpha2code according to Datex specification.
It allows the instantiation of Spain and the Czech Republic would be reusing the individuals from ISO3166-1-CountryCodes and  ISO639-1-LanguageCodes respectively.</skos:changeNote>
        <skos:changeNote xml:lang="en">2023-11-30. Renaming certain properties was done solely for organizational purposes, accompanied by the addition of specific domains and ranges to enhance property clarity.</skos:changeNote>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasOverallEndTime -->


    <owl:AnnotationProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasOverallEndTime"/>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasOverallStartTime -->


    <owl:AnnotationProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasOverallStartTime"/>
    




    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Datatypes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    




    <!-- http://datex2.eu/schema/3/Common/3_1#DateTime -->


    <rdfs:Datatype rdf:about="http://datex2.eu/schema/3/Common/3_1#DateTime">
        <skos:definition xml:lang="en">A combination of integer-valued year, month, day, hour, minute properties, a decimal-valued second property and a time zone property from which it is possible to determine the local time, the equivalent UTC time and the time zone offset from UTC.</skos:definition>
        <rdfs:isDefinedBy xml:lang="en">http://datex2.eu/schema/3/Common/3_1#</rdfs:isDefinedBy>
    </rdfs:Datatype>
    





    <!-- http://datex2.eu/schema/3/Common/3_1#Language -->


    <rdfs:Datatype rdf:about="http://datex2.eu/schema/3/Common/3_1#Language">
        <skos:definition xml:lang="en">A language datatype, identifies a specified language by an ISO 639-1 2-alpha code</skos:definition>
        <rdfs:isDefinedBy xml:lang="en">http://datex2.eu/schema/3/Common/3_1#</rdfs:isDefinedBy>
    </rdfs:Datatype>
    


    <!-- http://datex2.eu/schema/3/Common/3_1#MetresAsNonNegativeInteger -->


    <rdfs:Datatype rdf:about="http://datex2.eu/schema/3/Common/3_1#MetresAsNonNegativeInteger">
        <skos:definition xml:lang="en">A measure of distance defined in metres in a non negative integer format.</skos:definition>
        <rdfs:isDefinedBy xml:lang="en">http://datex2.eu/schema/3/Common/3_1#</rdfs:isDefinedBy>
    </rdfs:Datatype>
    


    <!-- http://datex2.eu/schema/3/Common/3_1#MultilingualString -->


    <rdfs:Datatype rdf:about="http://datex2.eu/schema/3/Common/3_1#MultilingualString">
        <skos:definition xml:lang="en">A multilingual string, whereby the same text may be expressed in more than one language.</skos:definition>
        <rdfs:isDefinedBy xml:lang="en">http://datex2.eu/schema/3/Common/3_1#</rdfs:isDefinedBy>
    </rdfs:Datatype>
    


    <!-- http://datex2.eu/schema/3/Common/3_1#NonNegativeInteger -->


    <rdfs:Datatype rdf:about="http://datex2.eu/schema/3/Common/3_1#NonNegativeInteger">
        <skos:definition xml:lang="en">An integer number whose value space is the set {0, 1, 2, ..., 2147483645, 2147483646, 2147483647}.</skos:definition>
        <rdfs:isDefinedBy xml:lang="en">http://datex2.eu/schema/3/Common/3_1#</rdfs:isDefinedBy>
    </rdfs:Datatype>
    


    <!-- http://datex2.eu/schema/3/Common/3_1#NutsCode -->


    <rdfs:Datatype rdf:about="http://datex2.eu/schema/3/Common/3_1#NutsCode">
        <skos:definition xml:lang="en">A NUTS code (Nomenclature of territorial units for statistics).</skos:definition>
        <rdfs:isDefinedBy xml:lang="en">http://datex2.eu/schema/3/Common/3_1#</rdfs:isDefinedBy>
    </rdfs:Datatype>
    



    <!-- http://datex2.eu/schema/3/Common/3_1#VehiclesPerHour -->


    <rdfs:Datatype rdf:about="http://datex2.eu/schema/3/Common/3_1#VehiclesPerHour">
        <skos:definition xml:lang="en">Vehicles per hour.</skos:definition>
        <rdfs:isDefinedBy xml:lang="en">http://datex2.eu/schema/3/Common/3_1#</rdfs:isDefinedBy>
    </rdfs:Datatype>
    


    <!-- http://qudt.org/schema/qudt/floatPercentage -->


    <rdfs:Datatype rdf:about="http://qudt.org/schema/qudt/floatPercentage">
        <skos:definition xml:lang="en">percentage in float</skos:definition>
        <rdfs:isDefinedBy xml:lang="en">http://qudt.org/2.1/schema/qudt</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">float percentage</rdfs:label>
    </rdfs:Datatype>
    





    <!-- http://www.openlinksw.com/schemas/virtrdf#geometry -->


    <rdfs:Datatype rdf:about="http://www.openlinksw.com/schemas/virtrdf#geometry">
        <skos:definition xml:lang="en">geometry</skos:definition>
        <rdfs:isDefinedBy xml:lang="en">http://www.openlinksw.com/schemas/virtrdf#</rdfs:isDefinedBy>
    </rdfs:Datatype>
    


    <!-- http://www.w3.org/2001/XMLSchema#ID -->


    <rdfs:Datatype rdf:about="http://www.w3.org/2001/XMLSchema#ID"/>
    


    <!-- http://www.w3.org/2001/XMLSchema#dateTimeStamp -->


    <rdf:Description rdf:about="http://www.w3.org/2001/XMLSchema#dateTimeStamp">
        <rdfs:label xml:lang="es">sello de tiempo</rdfs:label>
    </rdf:Description>
    


    <!-- http://www.w3.org/2001/XMLSchema#time -->


    <rdfs:Datatype rdf:about="http://www.w3.org/2001/XMLSchema#time"/>
    


    <!-- http://www.w3.org/2006/time#generalDay -->


    <rdfs:Datatype rdf:about="http://www.w3.org/2006/time#generalDay">
        <skos:definition xml:lang="en">Day of month - formulated as a text string with a pattern constraint to reproduce the same lexical form as gDay, except that values up to 99 are permitted, in order to support calendars with more than 31 days in a month. 
Note that the value-space is not defined, so a generic OWL2 processor cannot compute ordering relationships of values of this type.</skos:definition>
        <skos:definition xml:lang="es">Día del mes - formulado como una cadena de texto con una restricción patrón para reproducir la misma forma léxica que gDay, excepto que se permiten valores hasta el 99, con el propósito de proporcionar soporte a calendarios con meses con más de 31 días.
            Nótese que el espacio de valores no está definido, por tanto, un procesador genérico de OWL2 no puede computar relaciones de orden de valores de este tipo.</skos:definition>
        <rdfs:label xml:lang="es">Día generalizado</rdfs:label>
        <rdfs:label xml:lang="en">Generalized day</rdfs:label>
        <skos:definition xml:lang="en">Day of month - formulated as a text string with a pattern constraint to reproduce the same lexical form as gDay, except that values up to 99 are permitted, in order to support calendars with more than 31 days in a month. 
Note that the value-space is not defined, so a generic OWL2 processor cannot compute ordering relationships of values of this type.</skos:definition>
        <skos:definition xml:lang="es">Día del mes - formulado como una cadena de texto con una restricción patrón para reproducir la misma forma léxica que gDay, excepto que se permiten valores hasta el 99, con el propósito de proporcionar soporte a calendarios con meses con más de 31 días.
            Nótese que el espacio de valores no está definido, por tanto, un procesador genérico de OWL2 no puede computar relaciones de orden de valores de este tipo.</skos:definition>
    </rdfs:Datatype>
    


    <!-- http://www.w3.org/2006/time#generalMonth -->


    <rdfs:Datatype rdf:about="http://www.w3.org/2006/time#generalMonth">
        <skos:definition xml:lang="es">Mes del año - formulado como una cadena de texto con una restricción patrón para reproducir la misma forma léxica que gMonth, excepto que se permiten valores hasta el 20, con el propósito de proporcionar soporte a calendarios con años con más de 12 meses.
            Nótese que el espacio de valores no está definido, por tanto, un procesador genérico de OWL2 no puede computar relaciones de orden de valores de este tipo.</skos:definition>
        <skos:definition xml:lang="en">Month of year - formulated as a text string with a pattern constraint to reproduce the same lexical form as gMonth, except that values up to 20 are permitted, in order to support calendars with more than 12 months in the year. 
Note that the value-space is not defined, so a generic OWL2 processor cannot compute ordering relationships of values of this type.</skos:definition>
        <rdfs:label xml:lang="en">Generalized month</rdfs:label>
        <rdfs:label xml:lang="es">Mes generalizado</rdfs:label>
        <skos:definition xml:lang="es">Mes del año - formulado como una cadena de texto con una restricción patrón para reproducir la misma forma léxica que gMonth, excepto que se permiten valores hasta el 20, con el propósito de proporcionar soporte a calendarios con años con más de 12 meses.
            Nótese que el espacio de valores no está definido, por tanto, un procesador genérico de OWL2 no puede computar relaciones de orden de valores de este tipo.</skos:definition>
        <skos:definition xml:lang="en">Month of year - formulated as a text string with a pattern constraint to reproduce the same lexical form as gMonth, except that values up to 20 are permitted, in order to support calendars with more than 12 months in the year. 
Note that the value-space is not defined, so a generic OWL2 processor cannot compute ordering relationships of values of this type.</skos:definition>
    </rdfs:Datatype>
    


    <!-- http://www.w3.org/2006/time#generalYear -->


    <rdfs:Datatype rdf:about="http://www.w3.org/2006/time#generalYear">
        <skos:definition xml:lang="es">Número de año - formulado como una cadena de texto con una restricción patrón para reproducir la misma forma léxica que gYear, aunque no está restringido a valores del calendario gregoriano.
            Nótese que el espacio de valores no está definido, por tanto, un procesador genérico de OWL2 no puede computar relaciones de orden de valores de este tipo.</skos:definition>
        <skos:definition xml:lang="en">Year number - formulated as a text string with a pattern constraint to reproduce the same lexical form as gYear, but not restricted to values from the Gregorian calendar. 
Note that the value-space is not defined, so a generic OWL2 processor cannot compute ordering relationships of values of this type.</skos:definition>
        <rdfs:label xml:lang="es">Año generalizado</rdfs:label>
        <rdfs:label xml:lang="en">Generalized year</rdfs:label>
        <skos:definition xml:lang="es">Número de año - formulado como una cadena de texto con una restricción patrón para reproducir la misma forma léxica que gYear, aunque no está restringido a valores del calendario gregoriano.
            Nótese que el espacio de valores no está definido, por tanto, un procesador genérico de OWL2 no puede computar relaciones de orden de valores de este tipo.</skos:definition>
        <skos:definition xml:lang="en">Year number - formulated as a text string with a pattern constraint to reproduce the same lexical form as gYear, but not restricted to values from the Gregorian calendar. 
Note that the value-space is not defined, so a generic OWL2 processor cannot compute ordering relationships of values of this type.</skos:definition>
    </rdfs:Datatype>
    


    <!-- https://datex2.eu/schema/3/Common/3_1#MetresAsFloat -->


    <rdfs:Datatype rdf:about="https://datex2.eu/schema/3/Common/3_1#MetresAsFloat">
        <skos:definition xml:lang="en">A measure of distance defined in metres in a floating point format.</skos:definition>
        <rdfs:isDefinedBy xml:lang="en">http://datex2.eu/schema/3/Common/3_1#</rdfs:isDefinedBy>
    </rdfs:Datatype>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    



    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#allowedDeliveryChannel -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#allowedDeliveryChannel">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#HeaderInformation"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#InformationDeliveryServicesEnum"/>
        <skos:definition xml:lang="en">The allowed delivery channel.</skos:definition>
    </owl:ObjectProperty>
    



    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#confidentialityOverride -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#confidentialityOverride">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#SituationRecord"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#ConfidentialityValueEnum"/>
        <skos:definition xml:lang="en">The extent to which the related information may be circulated, according to the recipient type. Recipients must comply with this confidentiality statement. This overrides any confidentiality defined for the situation as a whole in the header information.</skos:definition>
    </owl:ObjectProperty>
    



    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#defaultLanguage -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#defaultLanguage">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#PayloadPublication"/>
        <rdfs:range rdf:resource="https://www.omg.org/spec/LCC/Languages/LanguageRepresentation/Alpha2Code"/>
        <skos:definition xml:lang="en">Specifies the language by an ISO 639-1 2-alpha code</skos:definition>
        <skos:definition xml:lang="en">The default language used throughout the payload publication</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#delayBand -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#delayBand">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#Delays"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#DelayBandEnum"/>
        <skos:definition xml:lang="en">The time band within which the additional travel time due to adverse travel conditions of any kind falls, when compared to &quot;normal conditions&quot;.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#delaysType -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#delaysType">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#Delays"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#DelaysTypeEnum"/>
        <skos:definition xml:lang="en">Coarse classification of the delay.</skos:definition>
    </owl:ObjectProperty>
    





    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#directionRelativeAtPoint -->

    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#directionRelativeAtPoint">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#PointAlongLinearElement"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#LinearDirectionEnum"/>
        <skos:definition xml:lang="en">The direction of traffic flow at the specified point relative to the direction in which the linear element is defined.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#directionRelativeOnLinearSection -->

    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#directionRelativeOnLinearSection">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#LinearWithinLinearElement"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#LinearDirectionEnum"/>
        <skos:definition xml:lang="en"></skos:definition>
        <skos:definition xml:lang="en">The direction of traffic flow on the linear section relative to the direction in which the linear element is defined.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#distanceAlong -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#distanceAlong">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#DistanceFromLinearElementReferent"/>
                    <rdf:Description rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#DistanceFromLinearElementStart"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#MetresAsFloatValue"/>
        <skos:definition xml:lang="en">A measure of distance along a linear element.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#geoSparqlObjectProperties -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#geoSparqlObjectProperties">
        <rdfs:subPropertyOf rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#importedObjectProperties"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <skos:definition xml:lang="en">Only for organizational purposes. GeoSparql object properties</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasAbnormalTrafficType -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasAbnormalTrafficType">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#AbnormalTraffic"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#AbnormalTrafficTypeEnum"/>
        <skos:definition xml:lang="en">A characterization of the nature of abnormal traffic flow, i.e. specifically relating to the nature of the traffic movement, implying a level of service.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasAccidentType -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasAccidentType">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#Accident"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#AccidentTypeEnum"/>
        <skos:definition xml:lang="en">A characterization of the nature of the accident.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasAdministrativeAreaOfLinearSection -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasAdministrativeAreaOfLinearSection">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#LinearWithinLinearElement"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti/administrativeUnit#AdministrativeUnit"/>
        <skos:definition xml:lang="en">Identification of the road administration area which contains the specified linear section.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasAdministrativeAreaOfPoint -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasAdministrativeAreaOfPoint">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#PointAlongLinearElement"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti/administrativeUnit#AdministrativeUnit"/>
        <skos:definition xml:lang="en">Identification of the road administration area which contains the specified point.</skos:definition>
    </owl:ObjectProperty>
    



    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasAlertCArea -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasAlertCArea">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#AreaLocation"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#AlertCArea"/>
        <skos:definition xml:lang="en">ALERT-C Area</skos:definition>
    </owl:ObjectProperty>
    



    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasAlertCLinear -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasAlertCLinear">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#SingleRoadLinearLocation"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#AlertCLinear"/>
        <skos:definition xml:lang="en">The linear location expressed using AlertC. Multiple instances of AlertCLinear shall represent the same real-world geographic feature.</skos:definition>
    </owl:ObjectProperty>
    




    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasAlertCPoint -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasAlertCPoint">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#PointLocation"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#AlertCPoint"/>
        <skos:definition xml:lang="en">A single point on the road network defined by reference to a pre-defined ALERT-C location table and which has an associated direction of traffic flow.</skos:definition>
        <skos:definition xml:lang="en">ALERT-C point</skos:definition>
        <skos:definition xml:lang="en">PointLocation is associated to AlertCPoint with cardinality 0..*</skos:definition>
        <skos:definition xml:lang="en">The point location expressed using AlertC. Multiple instances of AlertCPoint shall represent the same real-world geographic feature.They should represent the same point using different location tables.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasAltitudeAccuracyCodedValue -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasAltitudeAccuracyCodedValue">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#AltitudeConfidence"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#AltitudeAccuracyEnum"/>
        <skos:definition xml:lang="en">Absolute accuracy of reported value of a geographical point for a confidence level expressed by a coded scale.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasAltitudeConfidence -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasAltitudeConfidence">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#HeightCoordinate"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#AltitudeConfidence"/>
        <skos:definition xml:lang="en">Evaluation of the altitude confidence assessed according to ETSI ISO 102894-2</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasAnimalPresenceTypeEnum -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasAnimalPresenceTypeEnum">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#AnimalPresenceObstruction"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#AnimalPresenceTypeEmum"/>
        <skos:definition xml:lang="en">Indicates the nature of animals present on or near the roadway.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasAreaPlacesEnum -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasAreaPlacesEnum">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#AreaLocation"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#AreaPlacesEnum"/>
        <skos:definition xml:lang="en">Places, in generic terms, at which the corresponding information applies.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasCarriageway -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasCarriageway">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#SupplementaryPositionalDescription"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#Carriageway"/>
        <skos:definition xml:lang="en">Supplementary positional information which details carriageway and lane locations. Several instances may exist where the element being described extends over more than one carriageway.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasCarriagewayEnum -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasCarriagewayEnum">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#Carriageway"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#CarriagewayEnum"/>
        <skos:definition xml:lang="en">Indicates the section of carriageway to which the location relates.</skos:definition>
    </owl:ObjectProperty>
    



    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasComputationMethodEnum -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasComputationMethodEnum">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#DataValue"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#ComputationMethodEnum"/>
        <skos:definition xml:lang="en">Method of computation which has been used to compute this data value.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasConfidentiality -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasConfidentiality">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#HeaderInformation"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#ConfidentialityValueEnum"/>
        <skos:definition xml:lang="en">The extent to which the related information may be circulated, according to the recipient type. Recipients must comply with this confidentiality statement.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasConstructionWorkType -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasConstructionWorkType">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#ConstructionWorks"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#ConstructionWorkTypeEnum"/>
        <skos:definition xml:lang="en">The type of construction work being performed.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasCountrySubdivision -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasCountrySubdivision">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#IsoNamedArea"/>
        <rdfs:range rdf:resource="http://www.omg.org/spec/LCC/Countries/CountryRepresentation#CountrySubdivision"/>
        <skos:definition xml:lang="en">The ISO 3166-2 subdivision code for the named area.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasDelays -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasDelays">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#Impact"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#Delays"/>
        <skos:definition xml:lang="en">The details of the delays being caused by the situation element defined in the situation record. It is recommended to only use one of the optional attributes to avoid confusion.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasDirectionPurpose -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasDirectionPurpose">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#SupplementaryPositionalDescription"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#DirectionPurposeEnum"/>
        <skos:definition xml:lang="en">Identifies the main purpose of the road at the location</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasDistanceAlongLinearElement -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasDistanceAlongLinearElement">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#PointAlongLinearElement"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#DistanceAlongLinearElement"/>
        <skos:definition xml:lang="en">Distance of a point along a linear element either measured from the start node or a defined referent on that linear element, where the start node is relative to the element definition rather than the direction of traffic flow.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasDistanceAlongLinearElementFrom -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasDistanceAlongLinearElementFrom">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#LinearWithinLinearElement"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#DistanceAlongLinearElement"/>
        <skos:definition xml:lang="en">A point on the linear element that defines the start node of the linear section.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasDistanceAlongLinearElementTo -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasDistanceAlongLinearElementTo">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#LinearWithinLinearElement"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#DistanceAlongLinearElement"/>
        <skos:definition xml:lang="en">A point on the linear element that defines the end node of the linear section.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasDisturbanceActivityTypeEnum -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasDisturbanceActivityTypeEnum">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#DisturbanceActivity"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#DisturbanceActivityTypeEnum"/>
        <skos:definition xml:lang="en">Deliberate human action of either a public disorder nature or of a situation alert type which could disrupt traffic.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasDrivingConditionTypeEnum -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasDrivingConditionTypeEnum">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#Conditions"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#DrivingConditionTypeEnum"/>
        <skos:definition xml:lang="en">Types of the perceived driving conditions.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasEnvironmentalObstructionTypeEnum -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasEnvironmentalObstructionTypeEnum">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#EnvironmentalObstruction"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#EnvironmentalObstructionTypeEnum"/>
        <skos:definition xml:lang="en">Characterization of an obstruction on the road resulting from an environmental cause.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasGeneralInstructionOrMessageToRoadUsersType -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasGeneralInstructionOrMessageToRoadUsersType">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#GeneralInstructionOrMessageToRoadUsers"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#GeneralInstructionOrMessageToRoadUsersTypeEnum"/>
        <skos:definition>General instruction that is issued by the network/road operator which is applicable to drivers and sometimes passengers.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasGeneralNetworkManagementType -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasGeneralNetworkManagementType">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#GeneralNetworkManagement"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#GeneralNetworkManagementTypeEnum"/>
        <skos:definition>The type of traffic management action instigated by the network/road operator.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasGeographicDescriptor -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasGeographicDescriptor">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#SupplementaryPositionalDescription"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#GeographicCharacteristicEnum"/>
        <skos:definition xml:lang="en">Descriptor which identifies a geographic characteristic to help identify the specific location</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasGmlExteriorLinearRing -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasGmlExteriorLinearRing">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#GmlPolygon"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#GmlLinearRing"/>
        <skos:definition xml:lang="en">A boundary of a polygonal surface consisting of a ring i.e. in the normal 2D case, a closed polygonal line distinguished as exterior. Such a polygonal line has at least 4 pairs of coordinates</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasGmlInteriorLinearRing -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasGmlInteriorLinearRing">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#GmlPolygon"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#GmlLinearRing"/>
        <skos:definition xml:lang="en">A boundary of internal patches of a polygonal surface consisting of a ring feature</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasGmlLineString -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasGmlLineString">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#LinearElementByLineString"/>
                    <rdf:Description rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#LinearLocation"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#GmlLineString"/>
        <skos:definition xml:lang="en">Line string based on GML (EN ISO 19136) definition: a curve defined by a series of two or more coordinate tuples. Unlike GML may be self-intersecting. If srsName attribute is not present, posList is assumed to use &quot;ETRS89-LatLonh&quot; reference system.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasGmlMultiPolygon -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasGmlMultiPolygon">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#AreaLocation"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#GmlMultiPolygon"/>
        <skos:definition xml:lang="en">An area defined by a set of polygons acording to GML (EN ISO 19136).</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasGmlPolygon -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasGmlPolygon">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#GmlMultiPolygon"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#GmlPolygon"/>
        <skos:definition xml:lang="en">Planar surface defined by 1 exterior boundary and 0 or more interior boundaries</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasHeaderInformation -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasHeaderInformation">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#Situation"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#HeaderInformation"/>
        <skos:definition xml:lang="en">Management information relating to the data contained within a publication.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasHeightCoordinate -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasHeightCoordinate">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#PointCoordinates"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#HeightCoordinate"/>
        <skos:definition xml:lang="en">Third coordinate for points defined geodetically</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasHeightGradeOfLinearSection -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasHeightGradeOfLinearSection">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#LinearWithinLinearElement"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#HeightGradeEnum"/>
        <skos:definition xml:lang="en">Identification of whether the linear section that is part of the linear element is at, above or below the normal elevation of a linear element of that type (e.g. road or road section) at that location, typically used to indicate &quot;grade&quot; separation.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasHeightGradeOfPoint -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasHeightGradeOfPoint">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#PointAlongLinearElement"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#HeightGradeEnum"/>
        <skos:definition xml:lang="en">Identification of whether the point on the linear element is at, above or below the normal elevation of a linear element of that type (e.g. road or road section) at that location, typically used to indicate &quot;grade&quot; separation.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasHeightTypeEnum -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasHeightTypeEnum">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#HeightCoordinate"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#HeightTypeEnum"/>
        <skos:definition xml:lang="en">Type of measured height.When it is omitted it is supposed to be the ellipsoidal height.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasHorizontalPositionAccuracy -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasHorizontalPositionAccuracy">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#PointCoordinates"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#PositionAccuracy"/>
        <skos:definition xml:lang="en">Defines the horizontal position accuracy according EN 16803-1</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasImpact -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasImpact">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#SituationRecord"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#Impact"/>
        <skos:definition xml:lang="en">An assessment of the impact that an event or operator action defined by the situation record has on the driving conditions.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasImpactOnOppositeDirection -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasImpactOnOppositeDirection">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#SituationRecord"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#Impact"/>
        <skos:definition xml:lang="en">An assessment of the impact that an event or operator action defined by the situation record has on the driving conditions, but on opposite direction.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasInformationStatus -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasInformationStatus">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#HeaderInformation"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#InformationStatusEnum"/>
        <skos:definition xml:lang="en">The status of the related information (real, test, exercise ....).</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasInfrastructureDamageType -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasInfrastructureDamageType">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#InfrastructureDamageObstruction"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#InfrastructureDamageTypeEnum"/>
        <skos:definition xml:lang="en">Types of infrastructure damage which may have an effect on the road network.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasInfrastructureDescriptor -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasInfrastructureDescriptor">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#SupplementaryPositionalDescription"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#InfrastructureDescriptorEnum"/>
        <skos:definition xml:lang="en">Descriptor which identifies infrastructure to help identify the specific location.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasLane -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasLane">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#Carriageway"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#Lane"/>
        <skos:definition xml:lang="en">Indicates a specific lane or group of lanes.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasLaneEnum -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasLaneEnum">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#Lane"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#LaneEnum"/>
        <skos:definition xml:lang="en">Indicates the specific lane to which the location relates.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasLinearElement -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasLinearElement">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#LinearWithinLinearElement"/>
                    <rdf:Description rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#PointAlongLinearElement"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#LinearElement"/>
        <skos:definition xml:lang="en">Specifies a linear element along a single linear object, consistent with EN ISO 19148 definitions.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasLinearElementNature -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasLinearElementNature">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#LinearElement"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#LinearElementNatureEnum"/>
        <skos:definition xml:lang="en">An indication of the nature of the linear element.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasLinearWithinLinearElement -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasLinearWithinLinearElement">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#SingleRoadLinearLocation"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#LinearWithinLinearElement"/>
        <skos:definition xml:lang="en">Specifies a linear section along a linear element where the linear element is either a part of or the whole of a linear object (i.e. a road), consistent with ISO 19148 definitions.</skos:definition>
    </owl:ObjectProperty>
    



    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasLocationContainedInItinerary -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasLocationContainedInItinerary">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#ItineraryByIndexedLocations"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#Location"/>
        <skos:definition xml:lang="en">A location contained in an itinerary (i.e. an ordered set of locations defining a route or itinerary).</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasLocationReference -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasLocationReference">
        <owl:inverseOf rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#isLocationReferenceOf"/>
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#SituationRecord"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#LocationReference"/>
        <skos:definition xml:lang="en">Has a location reference</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasMaintenanceVehicleActions -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasMaintenanceVehicleActions">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#MaintenanceVehicles"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#MaintenanceVehicleActionsEnum"/>
        <skos:definition xml:lang="en">The actions of the maintenance vehicles associated with the roadworks activities.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasMaintenanceVehicles -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasMaintenanceVehicles">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#RoadWorks"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#MaintenanceVehicles"/>
        <skos:definition xml:lang="en">Details of the maintenance vehicles involved in the roadworks activity.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasMobility -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasMobility">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#SituationRecord"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#Mobility"/>
        <skos:definition xml:lang="en">An indication of whether the associated instance of a SituationRecord is mobile (e.g. a march or parade moving along a road) or stationary.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasMobilityOfActivity -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasMobilityOfActivity">
        <rdfs:subPropertyOf rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasMobility"/>
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#Activity"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#Mobility"/>
        <skos:definition xml:lang="en">Specifies the mobility of activity</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasMobilityOfObstruction -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasMobilityOfObstruction">
        <rdfs:subPropertyOf rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasMobility"/>
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#Obstruction"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#Mobility"/>
        <skos:definition xml:lang="en">Specifies the mobility of a obstruction</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasMobilityType -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasMobilityType">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#Mobility"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#MobilityTypeEnum"/>
        <skos:definition xml:lang="en">Types of mobility relating to a situation element defined by a SituationReord.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasNamedArea -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasNamedArea">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#AreaLocation"/>
                    <rdf:Description rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#SupplementaryPositionalDescription"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#NamedArea"/>
        <skos:definition xml:lang="en">An area defined by a name and/or in terms of known boundaries, such as country or county boundaries or allocated control area of particular authority. The attributes do not form a union; instead, the smallest intersection forms the resulting area.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasNamedAreaTypeEnum -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasNamedAreaTypeEnum">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#NamedArea"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#NamedAreaTypeEnum"/>
        <skos:definition xml:lang="en">The type of the area.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasNonWeatherRelatedRoadConditionTypeEnum -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasNonWeatherRelatedRoadConditionTypeEnum">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#NonWeatherRelatedRoadConditions"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#NonWeatherRelatedRoadConditionTypeEnum"/>
        <skos:definition xml:lang="en">The type of road conditions which are not related to the weather.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasNutsCodeTypeEnum -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasNutsCodeTypeEnum">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#NutsNamedArea"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#NutsCodeTypeEnum"/>
        <skos:definition xml:lang="en">The NUTS code type for the named area.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasObstructionTypeEnum -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasObstructionTypeEnum">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#GeneralObstruction"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#ObstructionTypeEnum"/>
        <skos:definition xml:lang="en">Characterization of the type of general obstruction.</skos:definition>
    </owl:ObjectProperty>
    



    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasOpenlrAreaLocationReference -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasOpenlrAreaLocationReference">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#AreaLocation"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#OpenlrAreaLocationReference"/>
        <skos:definition xml:lang="en">A two-dimensional part of the surface of the earth which is bounded by a closed curve. An area location may cover parts of the road network but does not necessarily need to. It is represented according to the OpenLR standard for Area Locations</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasOpenlrCoordinates -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasOpenlrCoordinates">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#OpenlrGeoCoordinate"/>
                    <rdf:Description rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#OpenlrPoiWithAccessPoint"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#PointCoordinates"/>
        <skos:definition xml:lang="en">Corresponding coordinates of an OpenLR point defined by its only coordinates.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasOpenlrFirstDirection -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasOpenlrFirstDirection">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#OpenlrLinear"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#OpenlrLineLocationReference"/>
        <skos:definition xml:lang="en">First OpenLR reference in first/main direction.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasOpenlrFormOfWayEnum -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasOpenlrFormOfWayEnum">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#OpenlrLineAttributes"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#OpenlrFormOfWayEnum"/>
        <skos:definition xml:lang="en">A classification based on the importance of the role that the Road Element (or Ferry Connection) performs in the connectivity of the total road network. (EN ISO 14825 § 7.2.88)</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasOpenlrGeoCoordinate -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasOpenlrGeoCoordinate">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#OpenlrCircleLocationReference"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#OpenlrGeoCoordinate"/>
        <skos:definition xml:lang="en">A geo-coordinate pair is a position in a map defined by its longitude and latitude coordinate values.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasOpenlrLastLocationReferencePoint -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasOpenlrLastLocationReferencePoint">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#OpenlrBasePointLocation"/>
                    <rdf:Description rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#OpenlrClosedLineLocationReference"/>
                    <rdf:Description rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#OpenlrLineLocationReference"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#OpenlrLastLocationReferencePoint"/>
        <skos:definition xml:lang="en">Allows defining the last point of the OpenLR path</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasOpenlrLineAttributes -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasOpenlrLineAttributes">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#OpenlrBaseReferencePoint"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#OpenlrLineAttributes"/>
        <skos:definition xml:lang="en">Properties of the line towards the topologically adjacent OpenLR location referencing point, on the shortest path to that point.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasOpenlrLinear -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasOpenlrLinear">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#LinearLocation"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#OpenlrLinear"/>
        <skos:definition xml:lang="en">OpenLR line location reference</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasOpenlrLocationReferencePoint -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasOpenlrLocationReferencePoint">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#OpenlrBasePointLocation"/>
                    <rdf:Description rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#OpenlrClosedLineLocationReference"/>
                    <rdf:Description rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#OpenlrLineLocationReference"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#OpenlrLocationReferencePoint"/>
        <skos:definition xml:lang="en">Allows defining the first point of the OpenLR path</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasOpenlrLowerLeft -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasOpenlrLowerLeft">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#OpenlrRectangle"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#PointCoordinates"/>
        <skos:definition xml:lang="en">The lower left corner of the rectangle.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasOpenlrLowestFrcToNextLRPoint -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasOpenlrLowestFrcToNextLRPoint">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#OpenlrLineAttributes"/>
                    <rdf:Description rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#OpenlrPathAttributes"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#OpenlrFunctionalRoadClassEnum"/>
        <skos:definition xml:lang="en">The lowest FRC to the next point indicates the lowest functional road class used in the location reference path to the next LR-point.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasOpenlrOffsets -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasOpenlrOffsets">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#OpenlrBasePointLocation"/>
                    <rdf:Description rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#OpenlrLinear"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#OpenlrOffsets"/>
        <skos:definition xml:lang="en">Allows for adding offsets to the line location path defined by nodes when the starting (respectively ending) point does not coincide with a node.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasOpenlrOppositeDirection -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasOpenlrOppositeDirection">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#OpenlrLinear"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#OpenlrLineLocationReference"/>
        <skos:definition xml:lang="en">If both direction, this is the reference in the opposite direction against firstDirection.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasOpenlrOrientation -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasOpenlrOrientation">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#OpenlrBasePointLocation"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#OpenlrOrientationEnum"/>
        <skos:definition xml:lang="en">Orientation of the driving direction in relation with the direction of the underlying linear</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasOpenlrPathAttributes -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasOpenlrPathAttributes">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#OpenlrLocationReferencePoint"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#OpenlrPathAttributes"/>
        <skos:definition xml:lang="en">Properties of the path from the associated location reference point to the next location reference point, which are specified to assist correct identification of the point in an external map data source.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasOpenlrPointLocationReference -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasOpenlrPointLocationReference">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#PointLocation"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#OpenlrPointLocationReference"/>
        <skos:definition xml:lang="en">PointLocation is associated to OpenlrPointLocationReference with cardinality 0..1</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasOpenlrPolygonCorners -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasOpenlrPolygonCorners">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#OpenlrPolygonLocationReference"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#OpenlrPolygonCorners"/>
        <skos:definition xml:lang="en">A geodetic coordinate Tuple that defines the vertices of the underlying geometrical polygon.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasOpenlrRectangle -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasOpenlrRectangle">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#OpenlrRectangleLocationReference"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#OpenlrRectangle"/>
        <skos:definition xml:lang="en">Area delimited by a rectangle defined by the geodetic co-ordinates of the two ends of its diagonal from south-west to north-east (the rectangle having two sides that are parallel to lines of latitude)</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasOpenlrSideOfRoad -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasOpenlrSideOfRoad">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#OpenlrBasePointLocation"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#OpenlrSideOfRoadEnum"/>
        <skos:definition xml:lang="en">Provides the of road where the corresponding point lies.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasOpenlrUpperRight -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasOpenlrUpperRight">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#OpenlrRectangle"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#PointCoordinates"/>
        <skos:definition xml:lang="en">The upper right corner of the rectangle.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasPointAlongLinearElement -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasPointAlongLinearElement">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#PointLocation"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#PointAlongLinearElement"/>
        <skos:definition xml:lang="en">PointLocation is associated to PointAlongLinearElement with cardinality 0..*</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasPointByCoordinates -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasPointByCoordinates">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#PointLocation"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#PointByCoordinates"/>
        <skos:definition xml:lang="en">PointLocation is associated to PointByCoordinates with cardinality 0..1</skos:definition>
    </owl:ObjectProperty>
    



    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasPoorEnvironmentTypeEnum -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasPoorEnvironmentTypeEnum">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#PoorEnvironmentConditions"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#PoorEnvironmentTypeEnum"/>
        <skos:definition xml:lang="en">Any environmental conditions which may be affecting the driving conditions on the road.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasPositionConfidenceCodedErrorEnum -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasPositionConfidenceCodedErrorEnum">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#AltitudeConfidence"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#PositionConfidenceCodedErrorEnum"/>
        <skos:definition xml:lang="en">Error code in case the altitude confidence is out of range or cannot be determined</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasPositionConfidenceEllipse -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasPositionConfidenceEllipse">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#PointCoordinates"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#PositionConfidenceEllipse"/>
        <skos:definition xml:lang="en">Confidence ellipse position defined in a shape of ellipse with a predefined confidence level (e.g. 95 %). The centre of the ellipse shape corresponds to the reference position point for which the position accuracy is evaluated.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasPositionOnCarriageway -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasPositionOnCarriageway">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#SupplementaryPositionalDescription"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#RelativePositionOnCarriagewayEnum"/>
        <skos:definition xml:lang="en">Relative position across carriageway</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasProbabilityOfOccurrence -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasProbabilityOfOccurrence">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#SituationRecord"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#ProbabilityOfOccurrenceEnum"/>
        <skos:definition xml:lang="en">An assessment of the degree of likelihood that the reported event will occur.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasPublicEventType -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasPublicEventType">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#PublicEvent"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#PublicEventTypeEnum"/>
        <skos:definition xml:lang="en">Specifies types of public events.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasReferent -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasReferent">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#DistanceFromLinearElementReferent"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#Referent"/>
        <skos:definition xml:lang="en">Specifies a referent on a linear object that has a known location such as a node, a reference marker (e.g. a marker-post), an intersection etc.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasReferentEndPointLinearElement -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasReferentEndPointLinearElement">
        <rdfs:subPropertyOf rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasReferent"/>
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#LinearElementByPoints"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#Referent"/>
        <skos:definition xml:lang="en">The referent at a known location on the linear object which defines the end of the linear element.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasReferentFrom -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasReferentFrom">
        <rdfs:subPropertyOf rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasReferent"/>
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#DistanceFromLinearElementReferent"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#Referent"/>
        <skos:definition xml:lang="en">A known location along the linear element from which the distanceAlong is measured, termed the &quot;fromReferent&quot; in EN ISO 19148.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasReferentIntermediatePointLinearElement -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasReferentIntermediatePointLinearElement">
        <rdfs:subPropertyOf rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasReferent"/>
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#LinearElementByPoints"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#Referent"/>
        <skos:definition xml:lang="en">A referent at a known location on the linear object which is neither the start or end of the linear element.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasReferentStartPointLinearElement -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasReferentStartPointLinearElement">
        <rdfs:subPropertyOf rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasReferent"/>
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#LinearElementByPoints"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#Referent"/>
        <skos:definition xml:lang="en">The referent at a known location on the linear object which defines the start of the linear element.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasReferentTowards -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasReferentTowards">
        <rdfs:subPropertyOf rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasReferent"/>
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#DistanceFromLinearElementReferent"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#Referent"/>
        <skos:definition xml:lang="en">A known location along the linear element towards which the distanceAlong is measured, termed the &quot;towardsReferent&quot; in EN ISO 19148.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasReferentTypeEnum -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasReferentTypeEnum">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#Referent"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#ReferentTypeEnum"/>
        <skos:definition xml:lang="en">The type of the referent.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasRelativeTrafficFlowEnum -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasRelativeTrafficFlowEnum">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#AbnormalTraffic"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#RelativeTrafficFlowEnum"/>
        <skos:definition xml:lang="en">Assessment of the traffic flow conditions relative to normally expected conditions at this date/time.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasReroutingManagementType -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasReroutingManagementType">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#ReroutingManagement"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#ReroutingManagementTypeEnum"/>
        <skos:definition xml:lang="en">Management actions relating to rerouting.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasRoadInformation -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasRoadInformation">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#SupplementaryPositionalDescription"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#RoadInformation"/>
        <skos:definition xml:lang="en">Information on a set of one or more roads. The location could correspond to a part of the road identified, the whole stretch of road identified, or a combination of multiple road sections.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasRoadMaintenanceType -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasRoadMaintenanceType">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#MaintenanceWorks"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#RoadMaintenanceTypeEnum"/>
        <skos:definition xml:lang="en">The type of road maintenance or installation work at the specified location.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasRoadNumber -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasRoadNumber">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#LinearElement"/>
                    <rdf:Description rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#RoadInformation"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti/roads#RoadNumber"/>
        <skos:definition xml:lang="en">Identifier/number of the road. The road number designated by the road authority</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasRoadOrCarriagewayOrLaneManagementType -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasRoadOrCarriagewayOrLaneManagementType">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#RoadOrCarriagewayOrLaneManagement"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#RoadOrCarriagewayOrLaneManagementTypeEnum"/>
        <skos:definition xml:lang="en">Management actions relating to road, carriageway or lane usage.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasRoadsideAssistenceTypeEnum -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasRoadsideAssistenceTypeEnum">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#RoadsideAssistance"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#RoadsideAssistenceTypeEnum"/>
        <skos:definition xml:lang="en">Indicates the nature of the road side assistance that will be, is or has been provided.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasRoadworksDuration -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasRoadworksDuration">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#RoadWorks"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#RoadworksDurationEnum"/>
        <skos:definition xml:lang="en">Indicates in general terms the expected duration of the roadworks.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasRoadworksScaleEnum -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasRoadworksScaleEnum">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#RoadWorks"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#RoadworksScaleEnum"/>
        <skos:definition xml:lang="en">Grade of complexity of the roadworks according to the responsible road operator. For example determined by size, duration and/or traffic disruption.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasSecondarySupplementaryDescription -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasSecondarySupplementaryDescription">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#LinearLocation"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#SupplementaryPositionalDescription"/>
        <skos:definition xml:lang="en">Supplementary description that applies to the secondary end of the linear location. Use when properties change along the Linear. For a one-way linear the secondary end should be the destination end.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasSemiMajorAxisLengthCodedError -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasSemiMajorAxisLengthCodedError">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#PositionConfidenceEllipse"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#PositionConfidenceCodedErrorEnum"/>
        <skos:definition xml:lang="en">Provides a coded error in case the semi-major axis length is not defined</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasSemiMinorAxisLengthCodedError -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasSemiMinorAxisLengthCodedError">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#PositionConfidenceEllipse"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#PositionConfidenceCodedErrorEnum"/>
        <skos:definition xml:lang="en">Provides a coded error in case the semi-minor axis length is not defined</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasSeverityEnum -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasSeverityEnum">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#SituationRecord"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#SeverityEnum"/>
        <skos:definition xml:lang="en">Levels of severity of a situation as whole assessed by the impact that the situation may have on traffic flow as perceived by the supplier.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasSituation -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasSituation">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#SituationPublication"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#Situation"/>
        <skos:definition xml:lang="en">traffic/travel situations.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasSituationRecord -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasSituationRecord">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#Situation"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#SituationRecord"/>
        <skos:definition xml:lang="en">Details of the Situation</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasSource -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasSource">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#SituationRecord"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#Source"/>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasSpeedManagementType -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasSpeedManagementType">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#SpeedManagement"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#SpeedManagementTypeEnum"/>
        <skos:definition xml:lang="en">Type of speed management action instigated by operator.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasSubdivisionTypeEnum -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasSubdivisionTypeEnum">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#IsoNamedArea"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#SubdivisionTypeEnum"/>
        <skos:definition xml:lang="en">The ISO 3166-2 subdivison type for the named area.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasSubject -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasSubject">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#SituationRecord"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#Subjects"/>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasSubjectTypeOfWorks -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasSubjectTypeOfWorks">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#Subjects"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#SubjectTypeOfWorksEnum"/>
        <skos:definition>The subject type of the roadworks (i.e. on what the construction or maintenance work is being performed).</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasSupplementaryPositionalDescription -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasSupplementaryPositionalDescription">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#NetworkLocation"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#SupplementaryPositionalDescription"/>
        <skos:definition xml:lang="en">A collection of supplementary positional information which improves the precision of the location.</skos:definition>
    </owl:ObjectProperty>
    



    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasTpegAreaLocation -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasTpegAreaLocation">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#AreaLocation"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#TpegAreaLocation"/>
        <skos:definition xml:lang="en">A geographic or geometric area defined by a TPEG-Loc structure which may include height information for additional geospatial discrimination.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasTpegLinearLocation -->

    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasTpegLinearLocation">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#SingleRoadLinearLocation"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#TpegLinearLocation"/>
        <skos:definition xml:lang="en">A linear section along a single road defined between two points on the same road by a TPEG-Loc structure.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasTpegOtherPointDescriptor -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasTpegOtherPointDescriptor">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#TpegJunction"/>
                    <rdf:Description rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#TpegNonJunctionPoint"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#TpegOtherPointDescriptor"/>
        <skos:definition xml:lang="en">A descriptive name which helps to identify the non-junction point. At least one descriptor must identify the road on which the point is located, i.e. must be of type &apos;linkName&apos; or &apos;localLinkName&apos;.</skos:definition>
    </owl:ObjectProperty>
    



    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasTrafficConstrictionTypeEnum -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasTrafficConstrictionTypeEnum">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#TrafficElement"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#TrafficConstrictionTypeEnum"/>
        <skos:definition xml:lang="en">Types of the constriction to which traffic is subjected as a result of an event.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasTrafficFlowCharacteristicsEnum -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasTrafficFlowCharacteristicsEnum">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#AbnormalTraffic"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#TrafficFlowCharateristicsEnum"/>
        <skos:definition xml:lang="en">The consistency (steadiness) of the traffic flow.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasTrafficTrendTypeEnum -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasTrafficTrendTypeEnum">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#AbnormalTraffic"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#TrafficTrendTypeEnum"/>
        <skos:definition xml:lang="en">A characterization of the trend in the traffic conditions at the specified location and direction.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasValidity -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasValidity">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#SituationRecord"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#Validity"/>
        <skos:definition xml:lang="en">Specification of validity, either explicitly or by a validity time period specification which may be discontinuous.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasValidityStatus -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasValidityStatus">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#Validity"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#ValidityStatusEnum"/>
        <skos:definition xml:lang="en">Specification of validity, either explicitly overriding the validity time specification or confirming it.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasVehicleCharacteristics -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasVehicleCharacteristics">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#Vehicle"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#VehicleCharacteristics"/>
        <skos:definition xml:lang="en">The characteristics of a vehicle, e.g. lorry of gross weight greater than 30 tonnes.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasVehicleObstructionTypeEnum -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasVehicleObstructionTypeEnum">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#VehicleObstruction"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#VehicleObstructionTypeEnum"/>
        <skos:definition xml:lang="en">Characterization of an obstruction on the road caused by one or more vehicles.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasVehicleStatus -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasVehicleStatus">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#Vehicle"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#VehicleStatusEnum"/>
        <skos:definition xml:lang="en">Vehicle status.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasVehicleTypeEnum -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasVehicleTypeEnum">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#VehicleCharacteristics"/>
                    <rdf:Description rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#VehicleObstruction"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#VehicleTypeEnum"/>
        <skos:definition xml:lang="en">Vehicle type.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasVehiclesInvolved -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasVehiclesInvolved">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#Accident"/>
                    <rdf:Description rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#VehicleObstruction"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#Vehicle"/>
        <skos:definition xml:lang="en">The vehicle involved in the accident.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasVerticalPositionAccuracy -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasVerticalPositionAccuracy">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#HeightCoordinate"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#PositionAccuracy"/>
        <skos:definition xml:lang="en">Defines the horizontal position accuracy according EN 16803-1</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasWeatherRelatedRoadConditionTypeEnum -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasWeatherRelatedRoadConditionTypeEnum">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#WeatherRelatedRoadConditions"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#WeatherRelatedRoadConditionType"/>
        <skos:definition xml:lang="en">The type of road surface condition that is related to the weather which is affecting the driving conditions.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasWinterEquipmentManagementType -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasWinterEquipmentManagementType">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#WinterDrivingManagement"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#WinterEquipmentManagementTypeEnum"/>
        <skos:definition xml:lang="en">Type of winter equipment management action instigated by operator.</skos:definition>
    </owl:ObjectProperty>
    



    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#heightValue -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#heightValue">
