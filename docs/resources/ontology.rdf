        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#MetresAsFloatValue"/>
        <skos:definition xml:lang="en">Value in metres for the height measured vertically at to the planar coordinates the point corresponding.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#importedObjectProperties -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#importedObjectProperties">
