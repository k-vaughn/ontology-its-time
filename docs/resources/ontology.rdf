                    <rdf:Description rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#damagedGallery"/>
                    <rdf:Description rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#damagedGantry"/>
                    <rdf:Description rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#damagedRoadSurface"/>
