                    <rdf:Description rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#blackIce"/>
                    <rdf:Description rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#ice"/>
                    <rdf:Description rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#icyPatches"/>
                    <rdf:Description rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#snowDrifts"/>
                    <rdf:Description rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#surfaceWater"/>
                </owl:oneOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#SituationEnumerations"/>
        <skos:definition xml:lang="en">Types of road surface conditions which are related to the weather.</skos:definition>
    </owl:Class>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#WeatherRelatedRoadConditions -->


    <owl:Class rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#WeatherRelatedRoadConditions">
        <rdfs:subClassOf rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#RoadSurfaceConditions"/>
        <rdfs:subClassOf>
            <owl:Class>
                <owl:complementOf rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#NonWeatherRelatedRoadConditions"/>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasWeatherRelatedRoadConditionTypeEnum"/>
                <owl:someValuesFrom rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#WeatherRelatedRoadConditionType"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <skos:definition xml:lang="en">Road surface conditions that are related to the weather which may affect the driving conditions, such as ice, snow or water.</skos:definition>
    </owl:Class>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#WinterDrivingManagement -->


    <owl:Class rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#WinterDrivingManagement">
        <rdfs:subClassOf rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#NetworkManagement"/>
        <skos:definition xml:lang="en">Winter driving management action that is instigated by the network/road operator.</skos:definition>
    </owl:Class>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#WinterEquipmentManagementTypeEnum -->


    <owl:Class rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#WinterEquipmentManagementTypeEnum">
        <owl:equivalentClass>
            <owl:Class>
                <owl:oneOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#doNoUseStudTyres"/>
                    <rdf:Description rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#other"/>
                    <rdf:Description rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#useSnowChains"/>
                    <rdf:Description rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#useSnowChainsOrTyres"/>
                    <rdf:Description rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#useSnowTyres"/>
                    <rdf:Description rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#winterEquipmentOnBoardRequired"/>
                </owl:oneOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#Non-SRTI_Enum"/>
        <skos:definition xml:lang="en">Type of winter equipment management action instigated by operator.</skos:definition>
    </owl:Class>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti/administrativeUnit#AdministrativeUnit -->


    <owl:Class rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti/administrativeUnit#AdministrativeUnit">
        <rdfs:subClassOf rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#CommonClasses"/>
        <skos:definition xml:lang="en">Used in DATEX II to identification of the road administration area which contains the specified linear section or point.</skos:definition>
    </owl:Class>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti/roads#RoadNumber -->


    <owl:Class rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti/roads#RoadNumber">
        <rdfs:subClassOf rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#SupplementaryPositionalPack"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#descriptor"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti/administrativeUnit#AdministrativeUnit"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <skos:definition xml:lang="en">The road number designated by the road authority</skos:definition>
    </owl:Class>
    


    <!-- http://data.europa.eu/nuts/code/ -->


    <owl:Class rdf:about="http://data.europa.eu/nuts/code/">
        <rdfs:subClassOf rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#CommonClasses"/>
        <skos:definition xml:lang="en">A NUTS code (Nomenclature of territorial units for statistics).</skos:definition>
        <rdfs:isDefinedBy>http://data.europa.eu/nuts/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">NutsResource</rdfs:label>
    </owl:Class>
    


    <!-- http://qudt.org/schema/qudt#QuantityValue -->


    <owl:Class rdf:about="http://qudt.org/schema/qudt#QuantityValue">
        <rdfs:subClassOf rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#DataValue"/>
        <dc:source xml:lang="en">http://qudt.org/schema/qudt#</dc:source>
        <skos:definition xml:lang="en">A quantity value expresses the numerical value of a quantity with respect to a chosen unit of measure.</skos:definition>
        <rdfs:isDefinedBy>http://qudt.org/schema/qudt#</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">QuantityValue</rdfs:label>
    </owl:Class>
    


    <!-- http://www.omg.org/spec/LCC/Countries/CountryRepresentation#Country -->


    <owl:Class rdf:about="http://www.omg.org/spec/LCC/Countries/CountryRepresentation#Country">
        <rdfs:subClassOf rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#LCC_CountryRepresentation"/>
        <skos:definition xml:lang="en">Country Code from LCC Countries Representation</skos:definition>
        <rdfs:isDefinedBy>http://www.omg.org/spec/LCC/Countries/CountryRepresentation#</rdfs:isDefinedBy>
    </owl:Class>
    


    <!-- http://www.omg.org/spec/LCC/Countries/CountryRepresentation#CountrySubdivision -->


    <owl:Class rdf:about="http://www.omg.org/spec/LCC/Countries/CountryRepresentation#CountrySubdivision">
        <rdfs:subClassOf rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#LCC_CountryRepresentation"/>
        <skos:definition xml:lang="en">Country Subdivision Code from LCC Countries Representation</skos:definition>
        <rdfs:isDefinedBy>http://www.omg.org/spec/LCC/Countries/CountryRepresentation#</rdfs:isDefinedBy>
    </owl:Class>
    


    <!-- http://www.omg.org/spec/LCC/Countries/CountryRepresentationi#Alpha2Code -->


    <owl:Class rdf:about="http://www.omg.org/spec/LCC/Countries/CountryRepresentationi#Alpha2Code">
        <rdfs:subClassOf rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#LCC_CountryRepresentation"/>
        <skos:definition xml:lang="en">A digraph representing a country or geographic region</skos:definition>
        <rdfs:isDefinedBy xml:lang="en">https://www.omg.org/spec/LCC/Countries/CountryRepresentation/</rdfs:isDefinedBy>
    </owl:Class>
    


    <!-- http://www.opengis.net/ont/geosparql#Feature -->


    <owl:Class rdf:about="http://www.opengis.net/ont/geosparql#Feature">
        <rdfs:subClassOf rdf:resource="http://www.opengis.net/ont/geosparql#SpatialObject"/>
        <owl:disjointWith rdf:resource="http://www.opengis.net/ont/geosparql#Geometry"/>
        <rdfs:isDefinedBy rdf:resource="http://www.opengis.net/ont/geosparql#"/>
        <rdfs:isDefinedBy rdf:resource="http://www.opengis.net/spec/geosparql/1.0/req/core/feature-class"/>
        <rdfs:isDefinedBy rdf:resource="http://www.opengis.net/spec/geosparql/1.1/req/core/feature-class"/>
        <skos:definition xml:lang="en">A discrete spatial phenomenon in a universe of discourse.</skos:definition>
        <skos:example rdf:resource="http://www.opengis.net/spec/geosparql/1.1/specification.html#B.1.1.2.1"/>
        <skos:example rdf:resource="http://www.opengis.net/spec/geosparql/1.1/specification.html#B.1.1.2.2"/>
        <skos:example rdf:resource="http://www.opengis.net/spec/geosparql/1.1/specification.html#B.1.1.2.3"/>
        <skos:example rdf:resource="http://www.opengis.net/spec/geosparql/1.1/specification.html#B.1.1.2.4"/>
        <skos:example rdf:resource="http://www.opengis.net/spec/geosparql/1.1/specification.html#B.1.1.2.5"/>
        <skos:example rdf:resource="http://www.opengis.net/spec/geosparql/1.1/specification.html#B.1.1.2.6"/>
        <skos:example rdf:resource="http://www.opengis.net/spec/geosparql/1.1/specification.html#B.1.1.2.7"/>
        <skos:example rdf:resource="http://www.opengis.net/spec/geosparql/1.1/specification.html#B.1.1.2.8"/>
        <skos:example rdf:resource="http://www.opengis.net/spec/geosparql/1.1/specification.html#B.1.1.2.9"/>
        <skos:example rdf:resource="http://www.opengis.net/spec/geosparql/1.1/specification.html#B.1.1.3.2"/>
        <skos:example rdf:resource="http://www.opengis.net/spec/geosparql/1.1/specification.html#B.1.1.3.3"/>
        <skos:example rdf:resource="http://www.opengis.net/spec/geosparql/1.1/specification.html#B.1.2.2"/>
        <skos:example rdf:resource="http://www.opengis.net/spec/geosparql/1.1/specification.html#B.1.2.3"/>
        <skos:example rdf:resource="http://www.opengis.net/spec/geosparql/1.1/specification.html#B.1.2.4"/>
        <skos:note xml:lang="en">A Feature represents a uniquely identifiable phenomenon, for example a river or an apple. While such phenomena (and therefore the Features used to represent them) are bounded, their boundaries may be crisp (e.g., the declared boundaries of a state), vague (e.g., the delineation of a valley versus its neighboring mountains), and change with time (e.g., a storm front). While discrete in nature, Features may be created from continuous observations, such as an isochrone that determines the region that can be reached by ambulance within 5 minutes.</skos:note>
        <skos:prefLabel xml:lang="en">Feature</skos:prefLabel>
    </owl:Class>
    


    <!-- http://www.opengis.net/ont/geosparql#FeatureCollection -->


    <owl:Class rdf:about="http://www.opengis.net/ont/geosparql#FeatureCollection">
        <rdfs:subClassOf rdf:resource="http://www.opengis.net/ont/geosparql#SpatialObjectCollection"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#member"/>
                <owl:allValuesFrom rdf:resource="http://www.opengis.net/ont/geosparql#Feature"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:isDefinedBy rdf:resource="http://www.opengis.net/ont/geosparql#"/>
        <rdfs:isDefinedBy rdf:resource="http://www.opengis.net/spec/geosparql/1.1/req/core/feature-collection-class"/>
        <skos:definition xml:lang="en">A collection of individual Features.</skos:definition>
        <skos:example rdf:resource="http://www.opengis.net/spec/geosparql/1.1/specification.html#B.1.1.6"/>
        <skos:prefLabel xml:lang="en">Feature Collection</skos:prefLabel>
    </owl:Class>
    


    <!-- http://www.opengis.net/ont/geosparql#Geometry -->


    <owl:Class rdf:about="http://www.opengis.net/ont/geosparql#Geometry">
        <rdfs:subClassOf rdf:resource="http://www.opengis.net/ont/geosparql#SpatialObject"/>
        <rdfs:isDefinedBy rdf:resource="http://www.opengis.net/ont/geosparql#"/>
        <rdfs:isDefinedBy rdf:resource="http://www.opengis.net/spec/geosparql/1.0/req/geometry-extension/geometry-class"/>
        <rdfs:isDefinedBy rdf:resource="http://www.opengis.net/spec/geosparql/1.1/req/geometry-extension/geometry-class"/>
        <skos:definition xml:lang="en">A coherent set of direct positions in space. The positions are held within a Spatial Reference System (SRS).</skos:definition>
        <skos:example rdf:resource="http://www.opengis.net/spec/geosparql/1.1/specification.html#B.1.1.2.2"/>
        <skos:example rdf:resource="http://www.opengis.net/spec/geosparql/1.1/specification.html#B.1.1.2.3"/>
        <skos:example rdf:resource="http://www.opengis.net/spec/geosparql/1.1/specification.html#B.1.1.2.4"/>
        <skos:example rdf:resource="http://www.opengis.net/spec/geosparql/1.1/specification.html#B.1.1.2.5"/>
        <skos:example rdf:resource="http://www.opengis.net/spec/geosparql/1.1/specification.html#B.1.1.2.6"/>
        <skos:example rdf:resource="http://www.opengis.net/spec/geosparql/1.1/specification.html#B.1.1.2.8"/>
        <skos:example rdf:resource="http://www.opengis.net/spec/geosparql/1.1/specification.html#B.1.1.3.1"/>
        <skos:example rdf:resource="http://www.opengis.net/spec/geosparql/1.1/specification.html#B.1.1.3.2"/>
        <skos:example rdf:resource="http://www.opengis.net/spec/geosparql/1.1/specification.html#B.1.1.3.3"/>
        <skos:example rdf:resource="http://www.opengis.net/spec/geosparql/1.1/specification.html#B.1.2.2"/>
        <skos:example rdf:resource="http://www.opengis.net/spec/geosparql/1.1/specification.html#B.1.2.3"/>
        <skos:example rdf:resource="http://www.opengis.net/spec/geosparql/1.1/specification.html#B.1.2.4"/>
        <skos:note xml:lang="en">Geometry can be used as a representation of the shape, extent or location of a Feature and may exist as a self-contained entity.</skos:note>
        <skos:prefLabel xml:lang="en">Geometry</skos:prefLabel>
    </owl:Class>
    


    <!-- http://www.opengis.net/ont/geosparql#GeometryCollection -->


    <owl:Class rdf:about="http://www.opengis.net/ont/geosparql#GeometryCollection">
        <rdfs:subClassOf rdf:resource="http://www.opengis.net/ont/geosparql#SpatialObjectCollection"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#member"/>
                <owl:allValuesFrom rdf:resource="http://www.opengis.net/ont/geosparql#Geometry"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:isDefinedBy rdf:resource="http://www.opengis.net/ont/geosparql#"/>
        <rdfs:isDefinedBy rdf:resource="http://www.opengis.net/spec/geosparql/1.1/req/core/geometry-collection-class"/>
        <skos:definition xml:lang="en">A collection of individual Geometries.</skos:definition>
        <skos:example rdf:resource="http://www.opengis.net/spec/geosparql/1.1/specification.html#B.1.1.7"/>
        <skos:prefLabel xml:lang="en">Geometry Collection</skos:prefLabel>
    </owl:Class>
    


    <!-- http://www.opengis.net/ont/geosparql#SpatialObject -->


    <owl:Class rdf:about="http://www.opengis.net/ont/geosparql#SpatialObject">
        <rdfs:subClassOf rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#GeoSparqlClasses"/>
        <rdfs:isDefinedBy rdf:resource="http://www.opengis.net/ont/geosparql#"/>
        <rdfs:isDefinedBy rdf:resource="http://www.opengis.net/spec/geosparql/1.0/req/core/spatial-object-class"/>
        <rdfs:isDefinedBy rdf:resource="http://www.opengis.net/spec/geosparql/1.1/req/core/spatial-object-class"/>
        <skos:definition xml:lang="en">Anything spatial (being or having a shape, position or an extent).</skos:definition>
        <skos:example rdf:resource="http://www.opengis.net/spec/geosparql/1.1/specification.html#B.1.1.1.1"/>
        <skos:example rdf:resource="http://www.opengis.net/spec/geosparql/1.1/specification.html#B.1.1.1.2"/>
        <skos:note xml:lang="en">Subclasses of this class are expected to be used for instance data.</skos:note>
        <skos:prefLabel xml:lang="en">Spatial Object</skos:prefLabel>
    </owl:Class>
    


    <!-- http://www.opengis.net/ont/geosparql#SpatialObjectCollection -->


    <owl:Class rdf:about="http://www.opengis.net/ont/geosparql#SpatialObjectCollection">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2000/01/rdf-schema#Container"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#member"/>
                <owl:allValuesFrom rdf:resource="http://www.opengis.net/ont/geosparql#SpatialObject"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:isDefinedBy rdf:resource="http://www.opengis.net/ont/geosparql#"/>
        <rdfs:isDefinedBy rdf:resource="http://www.opengis.net/spec/geosparql/1.1/req/core/spatial-object-collection-class"/>
        <skos:definition xml:lang="en">A collection of individual Spatial Objects.</skos:definition>
        <skos:note xml:lang="en">This is the superclass of Feature Collection and Geometry Collection.</skos:note>
        <skos:prefLabel xml:lang="en">Spatial Object Collection</skos:prefLabel>
    </owl:Class>
    


    <!-- http://www.w3.org/1999/02/22-rdf-syntax-ns#List -->


    <owl:Class rdf:about="http://www.w3.org/1999/02/22-rdf-syntax-ns#List">
        <rdfs:subClassOf rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#ImportedClasses"/>
        <skos:definition xml:lang="en">List</skos:definition>
    </owl:Class>
    


    <!-- http://www.w3.org/2002/07/owl#Thing -->


    <owl:Class rdf:about="http://www.w3.org/2002/07/owl#Thing"/>
    


    <!-- http://www.w3.org/2003/01/geo/wgs84_pos#Point -->


    <owl:Class rdf:about="http://www.w3.org/2003/01/geo/wgs84_pos#Point">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2003/01/geo/wgs84_pos#SpatialThing"/>
        <skos:definition> 
Uniquely identified by lat/long/alt. i.e.

spaciallyIntersects(P1, P2) :- lat(P1, LAT), long(P1, LONG), alt(P1, ALT),
  lat(P2, LAT), long(P2, LONG), alt(P2, ALT).

sameThing(P1, P2) :- type(P1, Point), type(P2, Point), spaciallyIntersects(P1, P2).
  </skos:definition>
        <skos:definition>A point, typically described using a coordinate system relative to Earth, such as WGS84.
  </skos:definition>
        <rdfs:isDefinedBy>http://www.w3.org/2003/01/geo/wgs84_pos#</rdfs:isDefinedBy>
        <rdfs:label>point</rdfs:label>
    </owl:Class>
    


    <!-- http://www.w3.org/2003/01/geo/wgs84_pos#SpatialThing -->


    <owl:Class rdf:about="http://www.w3.org/2003/01/geo/wgs84_pos#SpatialThing">
        <rdfs:subClassOf rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#Geo_WGS84DataPropertiesDataProperties"/>
        <skos:definition xml:lang="en">Spatial thing</skos:definition>
        <rdfs:isDefinedBy xml:lang="en">http://www.w3.org/2003/01/geo/wgs84_pos#</rdfs:isDefinedBy>
    </owl:Class>
    


    <!-- http://www.w3.org/2004/02/skos/core#Collection -->


    <owl:Class rdf:about="http://www.w3.org/2004/02/skos/core#Collection">
        <rdfs:subClassOf rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#SkosClasses"/>
    </owl:Class>
    


    <!-- http://www.w3.org/2004/02/skos/core#Concept -->


    <owl:Class rdf:about="http://www.w3.org/2004/02/skos/core#Concept">
        <rdfs:subClassOf rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#SkosClasses"/>
    </owl:Class>
    


    <!-- http://www.w3.org/2004/02/skos/core#ConceptScheme -->


    <owl:Class rdf:about="http://www.w3.org/2004/02/skos/core#ConceptScheme">
        <rdfs:subClassOf rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#SkosClasses"/>
    </owl:Class>
    




    <!-- https://ec.europa.eu/eurostat/ramon/ontologies/geographic.rdf#Region -->


    <owl:Class rdf:about="https://ec.europa.eu/eurostat/ramon/ontologies/geographic.rdf#Region">
        <rdfs:subClassOf rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#Ramon_geoClasses"/>
        <rdfs:isDefinedBy>https://ec.europa.eu/eurostat/ramon/</rdfs:isDefinedBy>
    </owl:Class>
    


    <!-- https://www.omg.org/spec/LCC/Languages/LanguageRepresentation/Alpha2Code -->


    <owl:Class rdf:about="https://www.omg.org/spec/LCC/Languages/LanguageRepresentation/Alpha2Code">
        <rdfs:subClassOf rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#CommonClasses"/>
        <skos:definition xml:lang="en">The default language used throughout the payload publication. Identifies a specified language by an ISO 639-1 2-alpha code.</skos:definition>
        <rdfs:isDefinedBy>https://www.omg.org/spec/LCC/Languages/LanguageRepresentation/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Language</rdfs:label>
        <skos:note xml:lang="en">In the ISO 639-1 language code, each language identifier is composed of two letters (lower case letters from the Latin alphabet, corresponding to characters 97 through 122 of the UTF-8 encoding), without diacritical marks or other encodings of any kind.</skos:note>
    </owl:Class>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Individuals
    //
