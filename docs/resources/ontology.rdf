        <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <skos:definition xml:lang="en">Only for organizational purposes. Imported object properties</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#isLocationReferenceOf -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#isLocationReferenceOf">
