                <owl:someValuesFrom rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#InfrastructureDamageTypeEnum"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <skos:definition xml:lang="en">An obstruction on the road caused by one Infrastructure Damage</skos:definition>
    </owl:Class>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#InfrastructureDamageTypeEnum -->


