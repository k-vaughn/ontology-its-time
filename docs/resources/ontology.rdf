    </owl:Class>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#ReroutingManagement -->


    <owl:Class rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#ReroutingManagement">
