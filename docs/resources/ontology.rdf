    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#AbnormalTraffic -->


    <owl:Class rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#AbnormalTraffic">
        <rdfs:subClassOf rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#TrafficElement"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasAbnormalTrafficType"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onClass rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#AbnormalTrafficTypeEnum"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasRelativeTrafficFlowEnum"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onClass rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#RelativeTrafficFlowEnum"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasTrafficFlowCharacteristicsEnum"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onClass rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#TrafficFlowCharateristicsEnum"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasTrafficTrendTypeEnum"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onClass rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#TrafficTrendTypeEnum"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#queueLength"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onClass rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#MetresAsNonNegativeIntegerValue"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#numberOfVehiclesWaiting"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://datex2.eu/schema/3/Common/3_1#NonNegativeInteger"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <skos:definition xml:lang="en">A traffic condition which is not normal.</skos:definition>
    </owl:Class>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#AbnormalTrafficTypeEnum -->


    <owl:Class rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#AbnormalTrafficTypeEnum">
        <owl:equivalentClass>
            <owl:Class>
                <owl:oneOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#heavyTraffic"/>
                    <rdf:Description rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#other"/>
                    <rdf:Description rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#queuingTraffic"/>
                    <rdf:Description rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#slowTraffic"/>
                    <rdf:Description rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#stationaryTraffic"/>
                    <rdf:Description rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#unspecifiedAbnormalTraffic"/>
                </owl:oneOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#Non-SRTI_Enum"/>
        <skos:definition xml:lang="en">Descriptive terms for abnormal traffic conditions specifically relating to the nature of the traffic movement, implying levels of service.</skos:definition>
    </owl:Class>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#Accident -->


    <owl:Class rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#Accident">
        <rdfs:subClassOf rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#TrafficElement"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasAccidentType"/>
                <owl:someValuesFrom rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#AccidentTypeEnum"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#Conditions"/>
        <owl:disjointWith rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#Obstruction"/>
        <skos:definition xml:lang="en">Accidents are events where one or more vehicles are involved in collisions or in leaving the roadway. These include collisions between vehicles or with other road users or obstacles.</skos:definition>
    </owl:Class>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#AccidentCauseEnum -->


    <owl:Class rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#AccidentCauseEnum">
        <owl:equivalentClass>
            <owl:Class>
                <owl:oneOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#avoidanceOfObstacles"/>
                    <rdf:Description rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#driverDistraction"/>
                    <rdf:Description rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#driverDrugAbuse"/>
                    <rdf:Description rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#driverIllness"/>
                    <rdf:Description rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#exceedingSpeedsLimits"/>
                    <rdf:Description rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#excessAlcohol"/>
                    <rdf:Description rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#excessiveDriverTiredness"/>
                    <rdf:Description rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#impermissibleManoeuvre"/>
                    <rdf:Description rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#limitedVisibility"/>
                    <rdf:Description rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#notKeepingASafeDistance"/>
                    <rdf:Description rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#onTheWrongSideOfTheRoad"/>
                    <rdf:Description rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#other"/>
                    <rdf:Description rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#pedestrianInRoad"/>
                    <rdf:Description rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#poorLaneAdherence"/>
                    <rdf:Description rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#poorMergeEntryOrExitJudgement"/>
                    <rdf:Description rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#poorRoadSurfaceCondition"/>
                    <rdf:Description rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#poorSurfaceAdherence"/>
                    <rdf:Description rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#undisclosed"/>
                    <rdf:Description rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#unknown"/>
                    <rdf:Description rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#vehicleFailure"/>
                </owl:oneOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#SituationEnumerations"/>
        <skos:definition xml:lang="en">Collection of descriptive terms for causes of accidents.</skos:definition>
    </owl:Class>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#AccidentTypeEnum -->


    <owl:Class rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#AccidentTypeEnum">
        <owl:equivalentClass>
            <owl:Class>
                <owl:oneOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#accident"/>
                    <rdf:Description rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#accidentInvolvingHazardousMaterials"/>
                    <rdf:Description rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#accidentInvolvingHeavyLorries"/>
                    <rdf:Description rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#collision"/>
                    <rdf:Description rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#multipleVehicleAccident"/>
                </owl:oneOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#SituationEnumerations"/>
        <skos:definition xml:lang="en">Collection of descriptive terms for types of accidents.</skos:definition>
    </owl:Class>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#Activity -->


    <owl:Class rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#Activity">
        <rdfs:subClassOf rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#TrafficElement"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasMobilityOfActivity"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onClass rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#Mobility"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <skos:definition xml:lang="en">A collection of information relating to human activities external to the traffic stream or roadway which could disrupt traffic.</skos:definition>
    </owl:Class>
    





    

    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#AngleInDegreesValue -->

    <owl:Class rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#AngleInDegreesValue">
        <rdfs:subClassOf rdf:resource="http://qudt.org/schema/qudt#QuantityValue"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://qudt.org/schema/qudt#unit"/>
                <owl:hasValue rdf:resource="http://qudt.org/vocab/unit/DEG"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://qudt.org/schema/qudt#numericValue"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <skos:definition xml:lang="en">A measured or  value of Angles. An integer number representing an angle in whole degrees between 0 and 359.</skos:definition>
    </owl:Class>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#AnimalPresenceObstruction -->


    <owl:Class rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#AnimalPresenceObstruction">
        <rdfs:subClassOf rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#Obstruction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasAnimalPresenceTypeEnum"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#AnimalPresenceTypeEmum"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#EnvironmentalObstruction"/>
        <owl:disjointWith rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#GeneralObstruction"/>
        <owl:disjointWith rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#VehicleObstruction"/>
        <skos:definition xml:lang="en">An obstruction on the road resulting from the presence of animals.</skos:definition>
    </owl:Class>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#AnimalPresenceTypeEmum -->


    <owl:Class rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#AnimalPresenceTypeEmum">
        <owl:equivalentClass>
            <owl:Class>
                <owl:oneOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#animalsOnTheRoad"/>
                    <rdf:Description rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#herdOfAnimalsOnTheRoad"/>
                    <rdf:Description rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#largeAnimalsOnTheRoad"/>
                </owl:oneOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#SituationEnumerations"/>
        <skos:definition xml:lang="en">Types of animal presence.</skos:definition>
    </owl:Class>
    




    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#Carriageway -->


    <owl:Class rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#Carriageway">
        <rdfs:subClassOf rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#SupplementaryPositionalPack"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasCarriagewayEnum"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#CarriagewayEnum"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#hasNamedArea"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onClass rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#NamedArea"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#originalNumberOfLanes"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <skos:definition xml:lang="en">Supplementary positional information which details carriageway and lane locations. Several instances may exist where the element being described extends over more than one carriageway.</skos:definition>
    </owl:Class>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#CarriagewayEnum -->


    <owl:Class rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#CarriagewayEnum">
