                <owl:onClass rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#InformationStatusEnum"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <skos:definition>Management information relating to the data contained within a publication.</skos:definition>
    </owl:Class>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#HeightCoordinate -->


    <owl:Class rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#HeightCoordinate">
