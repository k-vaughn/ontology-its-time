                <owl:onDataRange rdf:resource="http://datex2.eu/schema/3/Common/3_1#VehiclesPerHour"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <skos:definition xml:lang="en">A measured or calculated value of the flow rate of vehicles.</skos:definition>
    </owl:Class>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#VehicleObstruction -->


