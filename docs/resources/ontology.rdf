        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#SituationRecord"/>
        <skos:definition xml:lang="en">It is location reference of ...</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#lengthAffected -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#lengthAffected">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#SupplementaryPositionalDescription"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#MetresAsFloatValue"/>
        <skos:definition xml:lang="en">This indicates the length (measured in metres) of carriageway (and lanes) affected by the associated traffic element.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#locationPrecision -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#locationPrecision">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#SupplementaryPositionalDescription"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#MetresAsNonNegativeIntegerValue"/>
        <skos:definition xml:lang="en">Indicates that the location is given with a precision which is better than the stated value in metres.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#nutsCode -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#nutsCode">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#NutsNamedArea"/>
        <rdfs:range rdf:resource="http://data.europa.eu/nuts/code/"/>
        <skos:definition xml:lang="en">The NUTS code for the named area.</skos:definition>
    </owl:ObjectProperty>
    



    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#openlrBearing -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#openlrBearing">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#OpenlrLineAttributes"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#AngleInDegreesValue"/>
        <skos:definition xml:lang="en">Defines the bearing field as an integer value between 0 and 359</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#openlrNegativeOffset -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#openlrNegativeOffset">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#OpenlrOffsets"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#MetresAsNonNegativeIntegerValue"/>
        <skos:definition xml:lang="en">The negative offset along the line of the location measured along the line reference path between the end point of the location reference and the ending node of the line reference path.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#openlrPositiveOffset -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#openlrPositiveOffset">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#OpenlrOffsets"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#MetresAsNonNegativeIntegerValue"/>
        <skos:definition xml:lang="en">The positive offset along the line of the location measured along the line reference path between the start point of the location reference and the starting node of the line reference path.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#openlrRadius -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#openlrRadius">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#OpenlrCircleLocationReference"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#MetresAsNonNegativeIntegerValue"/>
        <skos:definition xml:lang="en">The radius of the corresponding circular area.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#publicationCreator -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#publicationCreator">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#PayloadPublication"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#InternationalIdentifier"/>
        <skos:definition xml:lang="en">Specifies the publication creator using an international identifier</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#qudtObjectProperties -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#qudtObjectProperties">
        <rdfs:subPropertyOf rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#importedObjectProperties"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <skos:definition xml:lang="en">Only for organizational purposes. Qudt object properties</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#queueLength -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#queueLength">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#AbnormalTraffic"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#MetresAsNonNegativeIntegerValue"/>
        <skos:definition xml:lang="en">The length of a queue or the average length of queues in separate lanes due to a situation.</skos:definition>
    </owl:ObjectProperty>
    



    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#residualLaneWidth -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#residualLaneWidth">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#Impact"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#MetresAsFloatValue"/>
        <skos:definition>The width of lanes after any lane narrowing</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#residualRoadWidth -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#residualRoadWidth">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#Impact"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#MetresAsFloatValue"/>
        <skos:definition>The total width of the combined operational lanes in the specified direction.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#semiMajorAxisLength -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#semiMajorAxisLength">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#PositionConfidenceEllipse"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#MetresAsFloatValue"/>
        <skos:definition xml:lang="en">Half of length of the major axis, i.e. distance between the centre point and major axis point of the position accuracy ellipse.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#semiMajorAxisOrientation -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#semiMajorAxisOrientation">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#PositionConfidenceEllipse"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#AngleInDegreesValue"/>
        <skos:definition xml:lang="en">Orientation direction of the ellipse major axis of the position accuracy ellipse with regards to the geographic north.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#semiMinorAxisLength -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#semiMinorAxisLength">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#PositionConfidenceEllipse"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#MetresAsFloatValue"/>
        <skos:definition xml:lang="en">Half of length of the minor axis, i.e. distance between the centre point and minor axis point of the position accuracy ellipse</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#skosObjectProperties -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#skosObjectProperties">
        <rdfs:subPropertyOf rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#importedObjectProperties"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <skos:definition xml:lang="en">Only for organizational purposes. Skos object properties</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#sourceCountry -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#sourceCountry">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#Source"/>
        <rdfs:range rdf:resource="http://www.omg.org/spec/LCC/Countries/CountryRepresentationi#Alpha2Code"/>
        <skos:definition xml:lang="en">EN ISO 3166-1 two-character country code of the source of the information.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#sourceType -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#sourceType">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#Source"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#SourceTypeEnum"/>
        <skos:definition xml:lang="en">Information about the technology used for measuring the data or the method used for obtaining qualitative descriptions relating to this version of the information.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#speed -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#speed">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#Mobility"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#SpeedValue"/>
        <skos:definition xml:lang="en">Speed of the mobile entity.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#temporarySpeedLimit -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#temporarySpeedLimit">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#SpeedManagement"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#SpeedValue"/>
        <skos:definition xml:lang="en">Temporary limit defining the maximum advisory or mandatory speed of vehicles.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#timeObjectProperties -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#timeObjectProperties">
        <rdfs:subPropertyOf rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#importedObjectProperties"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <skos:definition xml:lang="en">Only for organizational purposes. Time object properties</skos:definition>
    </owl:ObjectProperty>
    



    



    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#trafficManuallyDirectedBy -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#trafficManuallyDirectedBy">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#GeneralNetworkManagement"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#PersonCategoryEnum"/>
        <skos:definition xml:lang="en">Type of person that is manually directing traffic (applicable if generalNetworkManagementType is set to &quot;trafficBeingManuallyDirected&quot;).</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#validityTimeSpecification -->


    <owl:ObjectProperty rdf:about="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#validityTimeSpecification">
        <rdfs:domain rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#Validity"/>
        <rdfs:range rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#OverallPeriod"/>
        <skos:definition xml:lang="en">A specification of periods of validity defined by overall bounding start and end times and the possible intersection of valid periods with exception periods (exception periods overriding valid periods).</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://ec.europa.eu/eurostat/ramon/ontologies/geographic.rdf#ramon_geoObjectProperties -->


    <owl:ObjectProperty rdf:about="http://ec.europa.eu/eurostat/ramon/ontologies/geographic.rdf#ramon_geoObjectProperties">
        <rdfs:subPropertyOf rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#importedObjectProperties"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <skos:definition xml:lang="en">Only for organizational purposes. Ramon geographyt object properties</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://qudt.org/schema/qudt#unit -->


    <owl:ObjectProperty rdf:about="http://qudt.org/schema/qudt#unit">
        <rdfs:subPropertyOf rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#qudtObjectProperties"/>
        <skos:definition xml:lang="en">A reference to the unit of measure of a quantity (variable or constant) of interest.</skos:definition>
        <rdfs:isDefinedBy xml:lang="en">http://qudt.org/2.1/schema/qudt</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">unit</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.opengis.net/ont/geosparql#defaultGeometry -->


    <owl:ObjectProperty rdf:about="http://www.opengis.net/ont/geosparql#defaultGeometry">
        <owl:equivalentProperty rdf:resource="http://www.opengis.net/ont/geosparql#hasDefaultGeometry"/>
        <rdfs:subPropertyOf rdf:resource="http://www.opengis.net/ont/geosparql#hasGeometry"/>
        <rdfs:domain rdf:resource="http://www.opengis.net/ont/geosparql#Feature"/>
        <rdfs:range rdf:resource="http://www.opengis.net/ont/geosparql#Geometry"/>
        <rdfs:isDefinedBy rdf:resource="http://www.opengis.net/ont/geosparql#"/>
        <rdfs:isDefinedBy rdf:resource="http://www.opengis.net/spec/geosparql/1.1/req/geometry-extension/feature-properties"/>
        <skos:definition xml:lang="en">The default Geometry to be used in spatial calculations. It is usually the most detailed Geometry.</skos:definition>
        <skos:example rdf:resource="http://www.opengis.net/spec/geosparql/1.1/specification.html#B.1.2.2"/>
        <skos:example rdf:resource="http://www.opengis.net/spec/geosparql/1.1/specification.html#B.2.1"/>
        <skos:note xml:lang="en">Duplicate properties defaultGeometry and hasDefaultGeometry exist because of an inconsistency between ontology and documentation in GeoSPARQL 1.0. Only hasDefaultGeometry is described in the documention.</skos:note>
        <skos:prefLabel xml:lang="en">default geometry</skos:prefLabel>
    </owl:ObjectProperty>
    


    <!-- http://www.opengis.net/ont/geosparql#ehContains -->


    <owl:ObjectProperty rdf:about="http://www.opengis.net/ont/geosparql#ehContains">
        <rdfs:subPropertyOf rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#geoSparqlObjectProperties"/>
        <rdfs:domain rdf:resource="http://www.opengis.net/ont/geosparql#SpatialObject"/>
        <rdfs:range rdf:resource="http://www.opengis.net/ont/geosparql#SpatialObject"/>
        <rdfs:isDefinedBy rdf:resource="http://www.opengis.net/ont/geosparql#"/>
        <rdfs:isDefinedBy rdf:resource="http://www.opengis.net/spec/geosparql/1.0/req/geometry-extension/eh-spatial-relations"/>
        <rdfs:isDefinedBy rdf:resource="http://www.opengis.net/spec/geosparql/1.1/req/geometry-extension/eh-spatial-relations"/>
        <rdfs:seeAlso rdf:resource="http://dbpedia.org/resource/DE-9IM"/>
        <skos:definition xml:lang="en">States that the subject SpatialObject spatially contains the object SpatialObject. DE-9IM: T*TFF*FF*</skos:definition>
        <skos:prefLabel xml:lang="en">contains</skos:prefLabel>
    </owl:ObjectProperty>
    


    <!-- http://www.opengis.net/ont/geosparql#ehCoveredBy -->


    <owl:ObjectProperty rdf:about="http://www.opengis.net/ont/geosparql#ehCoveredBy">
        <rdfs:subPropertyOf rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#geoSparqlObjectProperties"/>
        <rdfs:domain rdf:resource="http://www.opengis.net/ont/geosparql#SpatialObject"/>
        <rdfs:range rdf:resource="http://www.opengis.net/ont/geosparql#SpatialObject"/>
        <rdfs:isDefinedBy rdf:resource="http://www.opengis.net/ont/geosparql#"/>
        <rdfs:isDefinedBy rdf:resource="http://www.opengis.net/spec/geosparql/1.0/req/geometry-extension/eh-spatial-relations"/>
        <rdfs:isDefinedBy rdf:resource="http://www.opengis.net/spec/geosparql/1.1/req/geometry-extension/eh-spatial-relations"/>
        <rdfs:seeAlso rdf:resource="http://dbpedia.org/resource/DE-9IM"/>
        <skos:definition xml:lang="en">States that the subject SpatialObject is spatially covered by the object SpatialObject. DE-9IM: TFF*TFT**</skos:definition>
        <skos:prefLabel xml:lang="en">covered by</skos:prefLabel>
    </owl:ObjectProperty>
    


    <!-- http://www.opengis.net/ont/geosparql#ehCovers -->


    <owl:ObjectProperty rdf:about="http://www.opengis.net/ont/geosparql#ehCovers">
        <rdfs:subPropertyOf rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#geoSparqlObjectProperties"/>
        <rdfs:domain rdf:resource="http://www.opengis.net/ont/geosparql#SpatialObject"/>
        <rdfs:range rdf:resource="http://www.opengis.net/ont/geosparql#SpatialObject"/>
        <rdfs:isDefinedBy rdf:resource="http://www.opengis.net/ont/geosparql#"/>
        <rdfs:isDefinedBy rdf:resource="http://www.opengis.net/spec/geosparql/1.0/req/geometry-extension/eh-spatial-relations"/>
        <rdfs:isDefinedBy rdf:resource="http://www.opengis.net/spec/geosparql/1.1/req/geometry-extension/eh-spatial-relations"/>
        <rdfs:seeAlso rdf:resource="http://dbpedia.org/resource/DE-9IM"/>
        <skos:definition xml:lang="en">States that the subject SpatialObject spatially covers the object SpatialObject. DE-9IM: T*TFT*FF*</skos:definition>
        <skos:prefLabel xml:lang="en">covers</skos:prefLabel>
    </owl:ObjectProperty>
    


    <!-- http://www.opengis.net/ont/geosparql#ehDisjoint -->


    <owl:ObjectProperty rdf:about="http://www.opengis.net/ont/geosparql#ehDisjoint">
        <owl:equivalentProperty rdf:resource="http://www.opengis.net/ont/geosparql#sfDisjoint"/>
        <rdfs:subPropertyOf rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#geoSparqlObjectProperties"/>
        <rdfs:domain rdf:resource="http://www.opengis.net/ont/geosparql#SpatialObject"/>
        <rdfs:range rdf:resource="http://www.opengis.net/ont/geosparql#SpatialObject"/>
        <rdfs:isDefinedBy rdf:resource="http://www.opengis.net/ont/geosparql#"/>
        <rdfs:isDefinedBy rdf:resource="http://www.opengis.net/spec/geosparql/1.0/req/geometry-extension/eh-spatial-relations"/>
        <rdfs:isDefinedBy rdf:resource="http://www.opengis.net/spec/geosparql/1.1/req/geometry-extension/eh-spatial-relations"/>
        <rdfs:seeAlso rdf:resource="http://dbpedia.org/resource/DE-9IM"/>
        <skos:definition xml:lang="en">States that the subject SpatialObject is spatially disjoint from the object SpatialObject. DE-9IM: FF*FF****</skos:definition>
        <skos:prefLabel xml:lang="en">disjoint</skos:prefLabel>
    </owl:ObjectProperty>
    


    <!-- http://www.opengis.net/ont/geosparql#ehEquals -->


    <owl:ObjectProperty rdf:about="http://www.opengis.net/ont/geosparql#ehEquals">
        <owl:equivalentProperty rdf:resource="http://www.opengis.net/ont/geosparql#sfEquals"/>
        <rdfs:subPropertyOf rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#geoSparqlObjectProperties"/>
        <rdfs:domain rdf:resource="http://www.opengis.net/ont/geosparql#SpatialObject"/>
        <rdfs:range rdf:resource="http://www.opengis.net/ont/geosparql#SpatialObject"/>
        <rdfs:isDefinedBy rdf:resource="http://www.opengis.net/ont/geosparql#"/>
        <rdfs:isDefinedBy rdf:resource="http://www.opengis.net/spec/geosparql/1.0/req/geometry-extension/eh-spatial-relations"/>
        <rdfs:isDefinedBy rdf:resource="http://www.opengis.net/spec/geosparql/1.1/req/geometry-extension/eh-spatial-relations"/>
        <rdfs:seeAlso rdf:resource="http://dbpedia.org/resource/DE-9IM"/>
        <skos:definition xml:lang="en">States that the subject SpatialObject spatially equals the object SpatialObject. DE-9IM: TFFFTFFFT</skos:definition>
        <skos:prefLabel xml:lang="en">equals</skos:prefLabel>
    </owl:ObjectProperty>
    


    <!-- http://www.opengis.net/ont/geosparql#ehInside -->


    <owl:ObjectProperty rdf:about="http://www.opengis.net/ont/geosparql#ehInside">
        <rdfs:subPropertyOf rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#geoSparqlObjectProperties"/>
        <rdfs:domain rdf:resource="http://www.opengis.net/ont/geosparql#SpatialObject"/>
        <rdfs:range rdf:resource="http://www.opengis.net/ont/geosparql#SpatialObject"/>
        <rdfs:isDefinedBy rdf:resource="http://www.opengis.net/ont/geosparql#"/>
        <rdfs:isDefinedBy rdf:resource="http://www.opengis.net/spec/geosparql/1.0/req/geometry-extension/eh-spatial-relations"/>
        <rdfs:isDefinedBy rdf:resource="http://www.opengis.net/spec/geosparql/1.1/req/geometry-extension/eh-spatial-relations"/>
        <rdfs:seeAlso rdf:resource="http://dbpedia.org/resource/DE-9IM"/>
        <skos:definition xml:lang="en">States that the subject SpatialObject is spatially inside the object SpatialObject. DE-9IM: TFF*FFT**</skos:definition>
        <skos:prefLabel xml:lang="en">inside</skos:prefLabel>
    </owl:ObjectProperty>
    


    <!-- http://www.opengis.net/ont/geosparql#ehMeet -->


    <owl:ObjectProperty rdf:about="http://www.opengis.net/ont/geosparql#ehMeet">
        <owl:equivalentProperty rdf:resource="http://www.opengis.net/ont/geosparql#sfTouches"/>
        <rdfs:subPropertyOf rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#geoSparqlObjectProperties"/>
        <rdfs:domain rdf:resource="http://www.opengis.net/ont/geosparql#SpatialObject"/>
        <rdfs:range rdf:resource="http://www.opengis.net/ont/geosparql#SpatialObject"/>
        <rdfs:isDefinedBy rdf:resource="http://www.opengis.net/ont/geosparql#"/>
        <rdfs:isDefinedBy rdf:resource="http://www.opengis.net/spec/geosparql/1.0/req/geometry-extension/eh-spatial-relations"/>
        <rdfs:isDefinedBy rdf:resource="http://www.opengis.net/spec/geosparql/1.1/req/geometry-extension/eh-spatial-relations"/>
        <rdfs:seeAlso rdf:resource="http://dbpedia.org/resource/DE-9IM"/>
        <skos:definition xml:lang="en">States that the subject SpatialObject spatially meets the object SpatialObject. DE-9IM: FT******* ^ F**T***** ^ F***T****</skos:definition>
        <skos:prefLabel xml:lang="en">meet</skos:prefLabel>
    </owl:ObjectProperty>
    


    <!-- http://www.opengis.net/ont/geosparql#ehOverlap -->


    <owl:ObjectProperty rdf:about="http://www.opengis.net/ont/geosparql#ehOverlap">
        <rdfs:subPropertyOf rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#geoSparqlObjectProperties"/>
        <rdfs:domain rdf:resource="http://www.opengis.net/ont/geosparql#SpatialObject"/>
        <rdfs:range rdf:resource="http://www.opengis.net/ont/geosparql#SpatialObject"/>
        <rdfs:isDefinedBy rdf:resource="http://www.opengis.net/ont/geosparql#"/>
        <rdfs:isDefinedBy rdf:resource="http://www.opengis.net/spec/geosparql/1.0/req/geometry-extension/eh-spatial-relations"/>
        <rdfs:isDefinedBy rdf:resource="http://www.opengis.net/spec/geosparql/1.1/req/geometry-extension/eh-spatial-relations"/>
        <rdfs:seeAlso rdf:resource="http://dbpedia.org/resource/DE-9IM"/>
        <skos:definition xml:lang="en">States that the subject SpatialObject spatially overlaps the object SpatialObject. DE-9IM: T*T***T**</skos:definition>
        <skos:prefLabel xml:lang="en">overlap</skos:prefLabel>
    </owl:ObjectProperty>
    


    <!-- http://www.opengis.net/ont/geosparql#hasArea -->


    <owl:ObjectProperty rdf:about="http://www.opengis.net/ont/geosparql#hasArea">
        <rdfs:subPropertyOf rdf:resource="http://www.opengis.net/ont/geosparql#hasSize"/>
        <rdfs:domain rdf:resource="http://www.opengis.net/ont/geosparql#SpatialObject"/>
        <rdfs:isDefinedBy rdf:resource="http://www.opengis.net/ont/geosparql#"/>
        <rdfs:isDefinedBy rdf:resource="http://www.opengis.net/spec/geosparql/1.1/req/geometry-extension/spatial-object-properties"/>
        <skos:definition xml:lang="en">The area of a Spatial Object.</skos:definition>
        <skos:example rdf:resource="http://www.opengis.net/spec/geosparql/1.1/specification.html#B.1.1.2.4"/>
        <skos:example rdf:resource="http://www.opengis.net/spec/geosparql/1.1/specification.html#B.1.2.2"/>
        <skos:prefLabel xml:lang="en">has area</skos:prefLabel>
    </owl:ObjectProperty>
    


    <!-- http://www.opengis.net/ont/geosparql#hasBoundingBox -->


    <owl:ObjectProperty rdf:about="http://www.opengis.net/ont/geosparql#hasBoundingBox">
        <rdfs:subPropertyOf rdf:resource="http://www.opengis.net/ont/geosparql#hasGeometry"/>
        <rdfs:domain rdf:resource="http://www.opengis.net/ont/geosparql#Feature"/>
        <rdfs:range rdf:resource="http://www.opengis.net/ont/geosparql#Geometry"/>
        <rdfs:isDefinedBy rdf:resource="http://www.opengis.net/ont/geosparql#"/>
        <rdfs:isDefinedBy rdf:resource="http://www.opengis.net/spec/geosparql/1.1/req/geometry-extension/feature-properties"/>
        <skos:definition xml:lang="en">The minimum or smallest bounding or enclosing box of a given Feature.</skos:definition>
        <skos:example rdf:resource="http://www.opengis.net/spec/geosparql/1.1/specification.html#B.1.2.2"/>
        <skos:prefLabel xml:lang="en">has bounding box</skos:prefLabel>
        <skos:scopeNote xml:lang="en">The target is a Geometry that defines a rectilinear region whose edges are aligned with the axes of the coordinate reference system, which exactly contains the Feature, for example an instance of http://www.opengis.net/ont/sf#envelope.</skos:scopeNote>
    </owl:ObjectProperty>
    


    <!-- http://www.opengis.net/ont/geosparql#hasCentroid -->


    <owl:ObjectProperty rdf:about="http://www.opengis.net/ont/geosparql#hasCentroid">
        <rdfs:subPropertyOf rdf:resource="http://www.opengis.net/ont/geosparql#hasGeometry"/>
        <rdfs:domain rdf:resource="http://www.opengis.net/ont/geosparql#Feature"/>
        <rdfs:range rdf:resource="http://www.opengis.net/ont/geosparql#Geometry"/>
        <rdfs:isDefinedBy rdf:resource="http://www.opengis.net/ont/geosparql#"/>
        <rdfs:isDefinedBy rdf:resource="http://www.opengis.net/spec/geosparql/1.1/req/geometry-extension/feature-properties"/>
        <skos:definition xml:lang="en">The arithmetic mean position of all the Geometry points of a given Feature.</skos:definition>
        <skos:example rdf:resource="http://www.opengis.net/spec/geosparql/1.1/specification.html#B.1.2.2"/>
        <skos:prefLabel xml:lang="en">has centroid</skos:prefLabel>
        <skos:scopeNote xml:lang="en">The target Geometry shall describe a point, for example an instance of http://www.opengis.net/ont/sf#Point.</skos:scopeNote>
    </owl:ObjectProperty>
    


    <!-- http://www.opengis.net/ont/geosparql#hasDefaultGeometry -->


    <owl:ObjectProperty rdf:about="http://www.opengis.net/ont/geosparql#hasDefaultGeometry">
        <rdfs:subPropertyOf rdf:resource="http://www.opengis.net/ont/geosparql#hasGeometry"/>
        <rdfs:domain rdf:resource="http://www.opengis.net/ont/geosparql#Feature"/>
        <rdfs:range rdf:resource="http://www.opengis.net/ont/geosparql#Geometry"/>
        <rdfs:isDefinedBy rdf:resource="http://www.opengis.net/ont/geosparql#"/>
        <rdfs:isDefinedBy rdf:resource="http://www.opengis.net/spec/geosparql/1.0/req/geometry-extension/feature-properties"/>
        <rdfs:isDefinedBy rdf:resource="http://www.opengis.net/spec/geosparql/1.1/req/geometry-extension/feature-properties"/>
        <skos:definition xml:lang="en">The default Geometry to be used in spatial calculations. It is usually the most detailed Geometry.</skos:definition>
        <skos:note xml:lang="en">Duplicate properties defaultGeometry and hasDefaultGeometry exist because of an inconsistency between ontology and documentation in GeoSPARQL 1.0. Only hasDefaultGeometry is described in the documention.</skos:note>
        <skos:prefLabel xml:lang="en">has default geometry</skos:prefLabel>
    </owl:ObjectProperty>
    


    <!-- http://www.opengis.net/ont/geosparql#hasGeometry -->


    <owl:ObjectProperty rdf:about="http://www.opengis.net/ont/geosparql#hasGeometry">
        <rdfs:subPropertyOf rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#geoSparqlObjectProperties"/>
        <rdfs:domain rdf:resource="http://www.opengis.net/ont/geosparql#Feature"/>
        <rdfs:range rdf:resource="http://www.opengis.net/ont/geosparql#Geometry"/>
        <rdfs:isDefinedBy rdf:resource="http://www.opengis.net/ont/geosparql#"/>
        <rdfs:isDefinedBy rdf:resource="http://www.opengis.net/spec/geosparql/1.0/req/geometry-extension/feature-properties"/>
        <rdfs:isDefinedBy rdf:resource="http://www.opengis.net/spec/geosparql/1.1/req/geometry-extension/feature-properties"/>
        <skos:definition xml:lang="en">A spatial representation for a given Feature.</skos:definition>
        <skos:example rdf:resource="http://www.opengis.net/spec/geosparql/1.1/specification.html#B.1.1.2.2"/>
        <skos:example rdf:resource="http://www.opengis.net/spec/geosparql/1.1/specification.html#B.1.1.2.3"/>
        <skos:example rdf:resource="http://www.opengis.net/spec/geosparql/1.1/specification.html#B.1.1.2.4"/>
        <skos:example rdf:resource="http://www.opengis.net/spec/geosparql/1.1/specification.html#B.1.1.2.5"/>
        <skos:example rdf:resource="http://www.opengis.net/spec/geosparql/1.1/specification.html#B.1.1.2.6"/>
        <skos:example rdf:resource="http://www.opengis.net/spec/geosparql/1.1/specification.html#B.1.1.2.8"/>
        <skos:example rdf:resource="http://www.opengis.net/spec/geosparql/1.1/specification.html#B.1.1.3.2"/>
        <skos:example rdf:resource="http://www.opengis.net/spec/geosparql/1.1/specification.html#B.1.1.3.3"/>
        <skos:example rdf:resource="http://www.opengis.net/spec/geosparql/1.1/specification.html#B.1.2.2"/>
        <skos:example rdf:resource="http://www.opengis.net/spec/geosparql/1.1/specification.html#B.1.2.3"/>
        <skos:example rdf:resource="http://www.opengis.net/spec/geosparql/1.1/specification.html#B.1.2.4"/>
        <skos:example rdf:resource="http://www.opengis.net/spec/geosparql/1.1/specification.html#B.2"/>
        <skos:prefLabel xml:lang="en">has geometry</skos:prefLabel>
    </owl:ObjectProperty>
    


    <!-- http://www.opengis.net/ont/geosparql#hasLength -->


    <owl:ObjectProperty rdf:about="http://www.opengis.net/ont/geosparql#hasLength">
        <rdfs:subPropertyOf rdf:resource="http://www.opengis.net/ont/geosparql#hasSize"/>
        <rdfs:domain rdf:resource="http://www.opengis.net/ont/geosparql#SpatialObject"/>
        <rdfs:isDefinedBy rdf:resource="http://www.opengis.net/ont/geosparql#"/>
        <rdfs:isDefinedBy rdf:resource="http://www.opengis.net/spec/geosparql/1.1/req/geometry-extension/spatial-object-properties"/>
        <skos:definition xml:lang="en">The length of a Spatial Object.</skos:definition>
        <skos:example rdf:resource="http://www.opengis.net/spec/geosparql/1.1/specification.html#B.1.1.2.7"/>
        <skos:example rdf:resource="http://www.opengis.net/spec/geosparql/1.1/specification.html#B.1.2.2"/>
        <skos:prefLabel xml:lang="en">has length</skos:prefLabel>
    </owl:ObjectProperty>
    


    <!-- http://www.opengis.net/ont/geosparql#hasPerimeterLength -->


    <owl:ObjectProperty rdf:about="http://www.opengis.net/ont/geosparql#hasPerimeterLength">
        <rdfs:subPropertyOf rdf:resource="http://www.opengis.net/ont/geosparql#hasSize"/>
        <rdfs:domain rdf:resource="http://www.opengis.net/ont/geosparql#SpatialObject"/>
        <rdfs:isDefinedBy rdf:resource="http://www.opengis.net/ont/geosparql#"/>
        <rdfs:isDefinedBy rdf:resource="http://www.opengis.net/spec/geosparql/1.1/req/geometry-extension/spatial-object-properties"/>
        <skos:definition xml:lang="en">The length of the perimeter of a Spatial Object.</skos:definition>
        <skos:example rdf:resource="http://www.opengis.net/spec/geosparql/1.1/specification.html#B.1.1.1.2"/>
        <skos:prefLabel xml:lang="en">has perimeter length</skos:prefLabel>
    </owl:ObjectProperty>
    


    <!-- http://www.opengis.net/ont/geosparql#hasSize -->


    <owl:ObjectProperty rdf:about="http://www.opengis.net/ont/geosparql#hasSize">
        <rdfs:domain rdf:resource="http://www.opengis.net/ont/geosparql#SpatialObject"/>
        <rdfs:isDefinedBy rdf:resource="http://www.opengis.net/ont/geosparql#"/>
        <rdfs:isDefinedBy rdf:resource="http://www.opengis.net/spec/geosparql/1.0/req/topology-vocab-extension/spatial-object-properties"/>
        <rdfs:isDefinedBy rdf:resource="http://www.opengis.net/spec/geosparql/1.1/req/topology-vocab-extension/spatial-object-properties"/>
        <skos:definition xml:lang="en">Subproperties of this property are used to indicate the size of a Spatial Object as a measurement or estimate of one or more dimensions of the Spatial Object&apos;s spatial presence.</skos:definition>
        <skos:note xml:lang="en">The recommended way to specify size is by using a subproperty of hasMetricSize. Subproperties of hasSize can be used if more complex expressions are necessary, for example if the unit of length can not be converted to meter, or if additional data are needed to describe the measurement or estimate.</skos:note>
        <skos:prefLabel xml:lang="en">has size</skos:prefLabel>
    </owl:ObjectProperty>
    


    <!-- http://www.opengis.net/ont/geosparql#hasSpatialAccuracy -->


    <owl:ObjectProperty rdf:about="http://www.opengis.net/ont/geosparql#hasSpatialAccuracy">
        <rdfs:domain rdf:resource="http://www.opengis.net/ont/geosparql#Geometry"/>
        <rdfs:isDefinedBy rdf:resource="http://www.opengis.net/ont/geosparql#"/>
        <rdfs:isDefinedBy rdf:resource="http://www.opengis.net/spec/geosparql/1.1/req/geometry-extension/geometry-properties"/>
        <skos:definition xml:lang="en">The positional accuracy of the coordinates of a Geometry.</skos:definition>
        <skos:example rdf:resource="http://www.opengis.net/spec/geosparql/1.1/specification.html#B.1.2.3"/>
        <skos:note xml:lang="en">Spatial accuracy is applicable when a Geometry is used to represent a Feature. It is expressed as a distance that indicates the truthfullness of the positions (coordinates) that define the Geometry. In this case accuracy defines a zone surrounding each coordinate within wich the real positions are known to be. The accuracy value defines this zone as a distance from the coordinate(s) in all directions (e.g. a line, a circle or a sphere, depending on spatial dimension).</skos:note>
        <skos:prefLabel xml:lang="en">has spatial accuracy</skos:prefLabel>
    </owl:ObjectProperty>
    


    <!-- http://www.opengis.net/ont/geosparql#hasSpatialResolution -->


    <owl:ObjectProperty rdf:about="http://www.opengis.net/ont/geosparql#hasSpatialResolution">
        <rdfs:domain rdf:resource="http://www.opengis.net/ont/geosparql#Geometry"/>
        <rdfs:isDefinedBy rdf:resource="http://www.opengis.net/ont/geosparql#"/>
        <rdfs:isDefinedBy rdf:resource="http://www.opengis.net/spec/geosparql/1.1/req/geometry-extension/feature-properties"/>
        <skos:definition xml:lang="en">The spatial resolution of a Geometry.</skos:definition>
        <skos:example rdf:resource="http://www.opengis.net/spec/geosparql/1.1/specification.html#B.1.2.2"/>
        <skos:note xml:lang="en">Spatial resolution specifies the level of detail of a Geometry. It the smallest distinguishable distance between spatially adjacent coordinates.</skos:note>
        <skos:prefLabel xml:lang="en">has spatial resolution</skos:prefLabel>
    </owl:ObjectProperty>
    


    <!-- http://www.opengis.net/ont/geosparql#hasVolume -->


    <owl:ObjectProperty rdf:about="http://www.opengis.net/ont/geosparql#hasVolume">
        <rdfs:subPropertyOf rdf:resource="http://www.opengis.net/ont/geosparql#hasSize"/>
        <rdfs:domain rdf:resource="http://www.opengis.net/ont/geosparql#SpatialObject"/>
        <rdfs:isDefinedBy rdf:resource="http://www.opengis.net/ont/geosparql#"/>
        <rdfs:isDefinedBy rdf:resource="http://www.opengis.net/spec/geosparql/1.1/req/geometry-extension/spatial-object-properties"/>
        <skos:definition xml:lang="en">The volume of a three-dimensional Spatial Object.</skos:definition>
        <skos:example rdf:resource="http://www.opengis.net/spec/geosparql/1.1/specification.html#B.1.2.2"/>
        <skos:prefLabel xml:lang="en">has volume</skos:prefLabel>
    </owl:ObjectProperty>
    


    <!-- http://www.opengis.net/ont/geosparql#rcc8dc -->


    <owl:ObjectProperty rdf:about="http://www.opengis.net/ont/geosparql#rcc8dc">
        <rdfs:subPropertyOf rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#geoSparqlObjectProperties"/>
        <rdfs:domain rdf:resource="http://www.opengis.net/ont/geosparql#SpatialObject"/>
        <rdfs:range rdf:resource="http://www.opengis.net/ont/geosparql#SpatialObject"/>
        <rdfs:isDefinedBy rdf:resource="http://www.opengis.net/ont/geosparql#"/>
        <rdfs:isDefinedBy rdf:resource="http://www.opengis.net/spec/geosparql/1.0/req/topology-vocab-extension/rcc8-spatial-relations"/>
        <rdfs:isDefinedBy rdf:resource="http://www.opengis.net/spec/geosparql/1.1/req/topology-vocab-extension/rcc8-spatial-relations"/>
        <rdfs:seeAlso rdf:resource="http://dbpedia.org/resource/DE-9IM"/>
        <skos:definition xml:lang="en">States that the subject SpatialObject is spatially disjoint from the object SpatialObject. DE-9IM: FFTFFTTTT</skos:definition>
        <skos:prefLabel xml:lang="en">disconnected</skos:prefLabel>
    </owl:ObjectProperty>
    


    <!-- http://www.opengis.net/ont/geosparql#rcc8ec -->


    <owl:ObjectProperty rdf:about="http://www.opengis.net/ont/geosparql#rcc8ec">
        <rdfs:subPropertyOf rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#geoSparqlObjectProperties"/>
        <rdfs:domain rdf:resource="http://www.opengis.net/ont/geosparql#SpatialObject"/>
        <rdfs:range rdf:resource="http://www.opengis.net/ont/geosparql#SpatialObject"/>
        <rdfs:isDefinedBy rdf:resource="http://www.opengis.net/ont/geosparql#"/>
        <rdfs:isDefinedBy rdf:resource="http://www.opengis.net/spec/geosparql/1.0/req/topology-vocab-extension/rcc8-spatial-relations"/>
        <rdfs:isDefinedBy rdf:resource="http://www.opengis.net/spec/geosparql/1.1/req/topology-vocab-extension/rcc8-spatial-relations"/>
        <rdfs:seeAlso rdf:resource="http://dbpedia.org/resource/DE-9IM"/>
        <skos:definition xml:lang="en">States that the subject SpatialObject spatially meets the object SpatialObject. DE-9IM: FFTFTTTTT</skos:definition>
        <skos:prefLabel xml:lang="en">externally connected</skos:prefLabel>
    </owl:ObjectProperty>
    


    <!-- http://www.opengis.net/ont/geosparql#rcc8eq -->


    <owl:ObjectProperty rdf:about="http://www.opengis.net/ont/geosparql#rcc8eq">
        <rdfs:subPropertyOf rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#geoSparqlObjectProperties"/>
        <rdfs:domain rdf:resource="http://www.opengis.net/ont/geosparql#SpatialObject"/>
        <rdfs:range rdf:resource="http://www.opengis.net/ont/geosparql#SpatialObject"/>
        <rdfs:isDefinedBy rdf:resource="http://www.opengis.net/ont/geosparql#"/>
        <rdfs:isDefinedBy rdf:resource="http://www.opengis.net/spec/geosparql/1.0/req/topology-vocab-extension/rcc8-spatial-relations"/>
        <rdfs:isDefinedBy rdf:resource="http://www.opengis.net/spec/geosparql/1.1/req/topology-vocab-extension/rcc8-spatial-relations"/>
        <rdfs:seeAlso rdf:resource="http://dbpedia.org/resource/DE-9IM"/>
        <skos:definition xml:lang="en">States that the subject SpatialObject spatially equals the object SpatialObject. DE-9IM: TFFFTFFFT</skos:definition>
        <skos:prefLabel xml:lang="en">equals</skos:prefLabel>
    </owl:ObjectProperty>
    


    <!-- http://www.opengis.net/ont/geosparql#rcc8ntpp -->


    <owl:ObjectProperty rdf:about="http://www.opengis.net/ont/geosparql#rcc8ntpp">
        <rdfs:subPropertyOf rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#geoSparqlObjectProperties"/>
        <rdfs:domain rdf:resource="http://www.opengis.net/ont/geosparql#SpatialObject"/>
        <rdfs:range rdf:resource="http://www.opengis.net/ont/geosparql#SpatialObject"/>
        <rdfs:isDefinedBy rdf:resource="http://www.opengis.net/ont/geosparql#"/>
        <rdfs:isDefinedBy rdf:resource="http://www.opengis.net/spec/geosparql/1.0/req/topology-vocab-extension/rcc8-spatial-relations"/>
        <rdfs:isDefinedBy rdf:resource="http://www.opengis.net/spec/geosparql/1.1/req/topology-vocab-extension/rcc8-spatial-relations"/>
        <rdfs:seeAlso rdf:resource="http://dbpedia.org/resource/DE-9IM"/>
        <skos:definition xml:lang="en">States that the subject SpatialObject is spatially inside the object SpatialObject. DE-9IM: TFFTFFTTT</skos:definition>
        <skos:prefLabel xml:lang="en">non-tangential proper part</skos:prefLabel>
    </owl:ObjectProperty>
    


    <!-- http://www.opengis.net/ont/geosparql#rcc8ntppi -->


    <owl:ObjectProperty rdf:about="http://www.opengis.net/ont/geosparql#rcc8ntppi">
        <rdfs:subPropertyOf rdf:resource="http://cef.uv.es/lodroadtran18/def/transporte/dtx_srti#geoSparqlObjectProperties"/>
        <rdfs:domain rdf:resource="http://www.opengis.net/ont/geosparql#SpatialObject"/>
        <rdfs:range rdf:resource="http://www.opengis.net/ont/geosparql#SpatialObject"/>
        <rdfs:isDefinedBy rdf:resource="http://www.opengis.net/ont/geosparql#"/>
        <rdfs:isDefinedBy rdf:resource="http://www.opengis.net/spec/geosparql/1.0/req/topology-vocab-extension/rcc8-spatial-relations"/>
        <rdfs:isDefinedBy rdf:resource="http://www.opengis.net/spec/geosparql/1.1/req/topology-vocab-extension/rcc8-spatial-relations"/>
        <rdfs:seeAlso rdf:resource="http://dbpedia.org/resource/DE-9IM"/>
        <skos:definition xml:lang="en">States that the subject SpatialObject spatially contains the object SpatialObject. DE-9IM: TTTFFTFFT</skos:definition>
        <skos:prefLabel xml:lang="en">non-tangential proper part inverse</skos:prefLabel>
    </owl:ObjectProperty>
    


    <!-- http://www.opengis.net/ont/geosparql#rcc8po -->


