        <rdfs:isDefinedBy rdf:resource="http://www.opengis.net/ont/geosparql#"/>
        <rdfs:isDefinedBy rdf:resource="http://www.opengis.net/spec/geosparql/1.1/req/geometry-extension/geometry-as-dggs-literal"/>
        <skos:definition xml:lang="en">The Discrete Global Grid System (DGGS) serialization of a Geometry</skos:definition>
        <skos:example rdf:resource="http://www.opengis.net/spec/geosparql/1.1/specification.html#B.1.2.4"/>
        <skos:prefLabel xml:lang="en">as DGGS</skos:prefLabel>
    </owl:DatatypeProperty>
    


